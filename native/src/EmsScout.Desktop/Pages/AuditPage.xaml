<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Name="AuditRoot"
    x:Class="EmsScout.Desktop.Pages.AuditPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:EmsScout.Desktop.ViewModels"
    Loaded="Page_Loaded"
    mc:Ignorable="d">
    <Grid Padding="{StaticResource PagePadding}" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Spacing="3">
                <TextBlock Style="{StaticResource WorkbenchPageTitleStyle}" Text="审计" />
                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind ViewModel.StatusText, Mode=OneWay}" />
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                <ComboBox
                    Width="250"
                    Header="数据批次"
                    DisplayMemberPath="DisplayText"
                    ItemsSource="{x:Bind ViewModel.DataContext.Options, Mode=OneWay}"
                    SelectedItem="{x:Bind ViewModel.DataContext.Selected, Mode=TwoWay}"
                    SelectionChanged="DataContext_SelectionChanged" />
                <Button Command="{x:Bind ViewModel.RunQualityAuditCommand}" Style="{StaticResource ToolbarButtonStyle}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon FontSize="14" Glyph="&#xE9D9;" />
                        <TextBlock Text="运行基础审计" />
                    </StackPanel>
                </Button>
                <Button Command="{x:Bind ViewModel.RunRealtimeAuditCommand}" Style="{StaticResource ToolbarButtonStyle}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon FontSize="14" Glyph="&#xE8B3;" />
                        <TextBlock Text="运行实时审计" />
                    </StackPanel>
                </Button>
                <Button Command="{x:Bind ViewModel.RefreshCommand}" Style="{StaticResource PrimaryToolbarButtonStyle}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon FontSize="14" Glyph="&#xE72C;" />
                        <TextBlock Text="刷新" />
                    </StackPanel>
                </Button>
                <Button Click="OpenData_Click" Style="{StaticResource ToolbarButtonStyle}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon FontSize="14" Glyph="&#xE8A5;" />
                        <TextBlock Text="数据管理" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <GridView
            Grid.Row="1"
            MaxHeight="112"
            IsItemClickEnabled="False"
            ItemsSource="{x:Bind ViewModel.Facets, Mode=OneWay}"
            SelectionMode="None"
            ScrollViewer.HorizontalScrollBarVisibility="Auto"
            ScrollViewer.VerticalScrollBarVisibility="Disabled">
            <GridView.ItemsPanel>
                <ItemsPanelTemplate>
                    <ItemsStackPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
            </GridView.ItemsPanel>
            <GridView.ItemContainerStyle>
                <Style TargetType="GridViewItem">
                    <Setter Property="MinWidth" Value="156" />
                    <Setter Property="MinHeight" Value="88" />
                </Style>
            </GridView.ItemContainerStyle>
            <GridView.ItemTemplate>
                <DataTemplate>
                    <Border Style="{StaticResource MetricCardStyle}">
                        <StackPanel Spacing="3">
                            <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{Binding Label}" />
                            <TextBlock FontSize="23" FontWeight="SemiBold" Text="{Binding Value}" />
                            <TextBlock Foreground="{ThemeResource TextFillColorTertiaryBrush}" Text="{Binding Detail}" />
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </GridView.ItemTemplate>
        </GridView>

        <Grid Grid.Row="2" ColumnSpacing="14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.05*" MinWidth="460" />
                <ColumnDefinition Width="1.35*" MinWidth="540" />
            </Grid.ColumnDefinitions>

            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="12">
                    <Border Style="{StaticResource WorkbenchCardStyle}">
                        <Grid RowSpacing="8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <StackPanel Spacing="2">
                                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="基础质量审计" />
                                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind ViewModel.QualityStatusText, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                                <TextBlock FontWeight="SemiBold" Text="{x:Bind ViewModel.QualitySummaryText, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                                <TextBlock Foreground="{ThemeResource TextFillColorTertiaryBrush}" Text="{x:Bind ViewModel.QualityGeneratedText, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                            </StackPanel>
                            <ListView
                                Grid.Row="2"
                                MaxHeight="190"
                                ItemsSource="{x:Bind ViewModel.QualityIssues, Mode=OneWay}"
                                SelectionMode="None">
                                <ListView.Header>
                                    <Grid Padding="0,0,0,6" ColumnSpacing="10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="132" />
                                            <ColumnDefinition Width="72" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock FontWeight="SemiBold" Text="级别 / 编码" />
                                        <TextBlock Grid.Column="1" FontWeight="SemiBold" Text="数量" />
                                        <TextBlock Grid.Column="2" FontWeight="SemiBold" Text="问题" />
                                    </Grid>
                                </ListView.Header>
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Padding="0,5" ColumnSpacing="10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="132" />
                                                <ColumnDefinition Width="72" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Spacing="1">
                                                <TextBlock FontWeight="SemiBold" Text="{Binding Severity}" />
                                                <TextBlock
                                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                    Text="{Binding Code}"
                                                    TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                            <TextBlock Grid.Column="1" Text="{Binding CountText}" />
                                            <TextBlock Grid.Column="2" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{Binding Message}" TextWrapping="WrapWholeWords" />
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource WorkbenchCardStyle}">
                        <StackPanel Spacing="8">
                            <TextBlock Style="{StaticResource SectionTitleStyle}" Text="计划状态审计" />
                            <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind ViewModel.ScheduleAuditSummaryText, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                            <ListView MaxHeight="230" ItemsSource="{x:Bind ViewModel.ScheduleAuditRows, Mode=OneWay}" SelectionMode="None">
                                <ListView.Header>
                                    <Grid ColumnSpacing="8">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="150" /><ColumnDefinition Width="100" /><ColumnDefinition Width="*" /><ColumnDefinition Width="100" /></Grid.ColumnDefinitions>
                                        <TextBlock FontWeight="SemiBold" Text="来源" />
                                        <TextBlock Grid.Column="1" FontWeight="SemiBold" Text="日期" />
                                        <TextBlock Grid.Column="2" FontWeight="SemiBold" Text="对象" />
                                        <TextBlock Grid.Column="3" FontWeight="SemiBold" Text="结果" />
                                    </Grid>
                                </ListView.Header>
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="vm:ScheduleAuditRow">
                                        <Grid ColumnSpacing="8" Padding="0,4">
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="150" /><ColumnDefinition Width="100" /><ColumnDefinition Width="*" /><ColumnDefinition Width="100" /></Grid.ColumnDefinitions>
                                            <TextBlock Text="{x:Bind Source}" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Grid.Column="1" Text="{x:Bind Date}" />
                                            <StackPanel Grid.Column="2" Spacing="1">
                                                <TextBlock Text="{x:Bind Target}" TextWrapping="WrapWholeWords" />
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <TextBlock Foreground="{ThemeResource TextFillColorTertiaryBrush}" Text="{x:Bind Interval}" />
                                                    <TextBlock Foreground="{ThemeResource TextFillColorTertiaryBrush}" Text="{x:Bind Expected}" />
                                                    <TextBlock Foreground="{ThemeResource TextFillColorTertiaryBrush}" Text="{x:Bind Actual}" />
                                                </StackPanel>
                                            </StackPanel>
                                            <TextBlock Grid.Column="3" Text="{x:Bind Result}" TextWrapping="WrapWholeWords" />
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource WorkbenchCardStyle}">
                        <Grid RowSpacing="8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <StackPanel Spacing="2">
                                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="实时点位审计" />
                                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind ViewModel.RealtimeQualityStatusText, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                                <TextBlock FontWeight="SemiBold" Text="{x:Bind ViewModel.RealtimeQualitySummaryText, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                                <TextBlock Foreground="{ThemeResource TextFillColorTertiaryBrush}" Text="{x:Bind ViewModel.RealtimeQualityGeneratedText, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                            </StackPanel>
                            <ItemsControl Grid.Row="1" ItemsSource="{x:Bind ViewModel.RealtimeQualityCategories, Mode=OneWay}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <ItemsWrapGrid Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border
                                            MinWidth="112"
                                            Margin="0,0,6,4"
                                            Padding="8,5"
                                            Background="{ThemeResource ControlFillColorDefaultBrush}"
                                            CornerRadius="6">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{Binding Label}" />
                                                <TextBlock FontWeight="SemiBold" Text="{Binding CountText}" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <ListView
                                Grid.Row="2"
                                MaxHeight="220"
                                ItemsSource="{x:Bind ViewModel.RealtimeQualityBuildings, Mode=OneWay}"
                                SelectionMode="None">
                                <ListView.Header>
                                    <Grid Padding="0,0,0,6" ColumnSpacing="10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="64" />
                                            <ColumnDefinition Width="82" />
                                            <ColumnDefinition Width="82" />
                                            <ColumnDefinition Width="82" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock FontWeight="SemiBold" Text="楼栋" />
                                        <TextBlock Grid.Column="1" FontWeight="SemiBold" Text="行数" />
                                        <TextBlock Grid.Column="2" FontWeight="SemiBold" Text="采集错" />
                                        <TextBlock Grid.Column="3" FontWeight="SemiBold" Text="异常" />
                                        <TextBlock Grid.Column="4" FontWeight="SemiBold" Text="主要类别" />
                                    </Grid>
                                </ListView.Header>
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Padding="0,5" ColumnSpacing="10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="64" />
                                                <ColumnDefinition Width="82" />
                                                <ColumnDefinition Width="82" />
                                                <ColumnDefinition Width="82" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock FontWeight="SemiBold" Text="{Binding Building}" />
                                            <TextBlock Grid.Column="1" Text="{Binding RowsText}" />
                                            <TextBlock Grid.Column="2" Text="{Binding CollectionErrorsText}" />
                                            <TextBlock Grid.Column="3" Text="{Binding DeviceAnomalyRowsText}" />
                                            <TextBlock Grid.Column="4" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{Binding MainCategoryText}" TextWrapping="WrapWholeWords" />
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Grid>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <Grid Grid.Column="1" RowSpacing="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="1.2*" />
                    <RowDefinition Height="0.95*" />
                </Grid.RowDefinitions>

                <Border Style="{StaticResource WorkbenchCardStyle}">
                    <Grid RowSpacing="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="2">
                                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="实时对账" />
                                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind ViewModel.ReconciliationStatusText, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                            </StackPanel>
                            <Button
                                Grid.Column="1"
                                Command="{x:Bind ViewModel.OpenReconciliationItemCommand}"
                                Style="{StaticResource ToolbarButtonStyle}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon FontSize="14" Glyph="&#xE8A5;" />
                                    <TextBlock Text="定位数据" />
                                </StackPanel>
                            </Button>
                        </Grid>

                        <Grid Grid.Row="1" ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="118" />
                                <ColumnDefinition Width="132" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ComboBox
                                DisplayMemberPath="Label"
                                ItemsSource="{x:Bind ViewModel.ReconciliationBuildingOptions, Mode=OneWay}"
                                SelectedItem="{x:Bind ViewModel.SelectedReconciliationBuilding, Mode=TwoWay}" />
                            <ComboBox
                                Grid.Column="1"
                                DisplayMemberPath="Label"
                                ItemsSource="{x:Bind ViewModel.ReconciliationTypeOptions, Mode=OneWay}"
                                SelectedItem="{x:Bind ViewModel.SelectedReconciliationType, Mode=TwoWay}" />
                            <TextBox
                                Grid.Column="2"
                                PlaceholderText="设备名 / DevId / 证据"
                                Text="{x:Bind ViewModel.ReconciliationSearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Grid.Column="3" Command="{x:Bind ViewModel.ApplyReconciliationFilterCommand}" Style="{StaticResource PrimaryToolbarButtonStyle}" Content="筛选" />
                        </Grid>

                        <StackPanel Grid.Row="2" Spacing="4">
                            <TextBlock FontWeight="SemiBold" Text="{x:Bind ViewModel.ReconciliationSummaryText, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                            <TextBlock Foreground="{ThemeResource TextFillColorTertiaryBrush}" Text="{x:Bind ViewModel.ReconciliationGeneratedText, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                            <ItemsControl ItemsSource="{x:Bind ViewModel.ReconciliationTypeCounts, Mode=OneWay}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <ItemsWrapGrid Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border
                                            MinWidth="96"
                                            Margin="0,0,6,4"
                                            Padding="8,5"
                                            Background="{ThemeResource ControlFillColorDefaultBrush}"
                                            CornerRadius="6">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{Binding Label}" />
                                                <TextBlock FontWeight="SemiBold" Text="{Binding CountText}" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <Grid Grid.Row="3" ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.05*" />
                                <ColumnDefinition Width="0.95*" />
                            </Grid.ColumnDefinitions>
                            <ListView
                                ItemsSource="{x:Bind ViewModel.ReconciliationItems, Mode=OneWay}"
                                SelectedItem="{x:Bind ViewModel.SelectedReconciliationItem, Mode=TwoWay}"
                                SelectionMode="Single">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Padding="0,5" ColumnSpacing="10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="78" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="52" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Spacing="2">
                                                <TextBlock FontWeight="SemiBold" Text="{Binding TypeLabel}" TextWrapping="WrapWholeWords" />
                                                <TextBlock Foreground="{ThemeResource TextFillColorTertiaryBrush}" Text="{Binding Severity}" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Spacing="2">
                                                <TextBlock FontWeight="SemiBold" Text="{Binding Name}" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{Binding Building}" />
                                            </StackPanel>
                                            <TextBlock Grid.Column="2" HorizontalAlignment="Right" Text="{Binding ConfidenceText}" />
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>

                            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                                <StackPanel Spacing="7">
                                    <StackPanel Spacing="2">
                                        <TextBlock FontWeight="SemiBold" Text="{x:Bind ViewModel.SelectedReconciliationItem.Name, Mode=OneWay, FallbackValue=未选择}" TextWrapping="WrapWholeWords" />
                                        <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind ViewModel.SelectedReconciliationItem.Location, Mode=OneWay, FallbackValue=--}" TextWrapping="WrapWholeWords" />
                                    </StackPanel>
                                    <Grid ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="DevId" />
                                        <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.SelectedReconciliationItem.DevId, Mode=OneWay, FallbackValue=--}" TextTrimming="CharacterEllipsis" />
                                    </Grid>
                                    <TextBlock FontWeight="SemiBold" Text="归因" />
                                    <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind ViewModel.SelectedReconciliationItem.Reason, Mode=OneWay, FallbackValue=--}" TextWrapping="WrapWholeWords" />
                                    <Expander HorizontalContentAlignment="Stretch">
                                        <Expander.Header>
                                            <TextBlock FontWeight="SemiBold" Text="证据与规则" />
                                        </Expander.Header>
                                        <StackPanel Spacing="6">
                                            <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind ViewModel.SelectedReconciliationItem.RuleDescription, Mode=OneWay, FallbackValue=--}" TextWrapping="WrapWholeWords" />
                                            <TextBlock Text="{x:Bind ViewModel.SelectedReconciliationItem.EvidenceSummary, Mode=OneWay, FallbackValue=--}" TextWrapping="WrapWholeWords" />
                                            <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind ViewModel.SelectedReconciliationItem.DecisionPathText, Mode=OneWay, FallbackValue=--}" TextWrapping="WrapWholeWords" />
                                        </StackPanel>
                                    </Expander>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </Grid>
                </Border>

                <Border Grid.Row="1" Style="{StaticResource WorkbenchCardStyle}">
                    <Grid RowSpacing="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <StackPanel Spacing="2">
                            <TextBlock Style="{StaticResource SectionTitleStyle}" Text="历史批次" />
                            <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind ViewModel.RunsStatusText, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                        </StackPanel>
                        <ListView
                            Grid.Row="1"
                            ItemsSource="{x:Bind ViewModel.Runs, Mode=OneWay}"
                            SelectedItem="{x:Bind ViewModel.SelectedRun, Mode=TwoWay}"
                            SelectionMode="Single">
                            <ListView.Header>
                                <Grid Padding="0,0,0,6" ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1.25*" />
                                        <ColumnDefinition Width="0.8*" />
                                        <ColumnDefinition Width="0.8*" />
                                        <ColumnDefinition Width="0.8*" />
                                        <ColumnDefinition Width="1.4*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock FontWeight="SemiBold" Text="完成时间 / 批次" />
                                    <TextBlock Grid.Column="1" FontWeight="SemiBold" Text="范围" />
                                    <TextBlock Grid.Column="2" FontWeight="SemiBold" Text="卡片数" />
                                    <TextBlock Grid.Column="3" FontWeight="SemiBold" Text="状态" />
                                    <TextBlock Grid.Column="4" FontWeight="SemiBold" Text="备注" />
                                </Grid>
                            </ListView.Header>
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Padding="0,5" ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="1.25*" />
                                            <ColumnDefinition Width="0.8*" />
                                            <ColumnDefinition Width="0.8*" />
                                            <ColumnDefinition Width="0.8*" />
                                            <ColumnDefinition Width="1.4*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Spacing="2">
                                            <TextBlock FontWeight="SemiBold" Text="{Binding CompletedAt}" />
                                            <TextBlock Foreground="{ThemeResource TextFillColorTertiaryBrush}" Text="{Binding RunKey}" />
                                        </StackPanel>
                                        <TextBlock Grid.Column="1" Text="{Binding ScopeLabel}" TextWrapping="WrapWholeWords" />
                                        <TextBlock Grid.Column="2" Text="{Binding CountLabel}" />
                                        <TextBlock Grid.Column="3" Text="{Binding StateLabel}" />
                                        <TextBlock Grid.Column="4" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{Binding Note}" TextWrapping="WrapWholeWords" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8">
                            <Button Command="{x:Bind ViewModel.MarkRunAnomalyCommand}" Style="{StaticResource ToolbarButtonStyle}" Content="标记异常" />
                            <Button Command="{x:Bind ViewModel.ClearRunAnomalyCommand}" Style="{StaticResource ToolbarButtonStyle}" Content="取消异常" />
                            <Button
                                Click="RestoreRun_Click"
                                IsEnabled="{x:Bind ViewModel.CanRestoreSelectedRun, Mode=OneWay}"
                                Style="{StaticResource ToolbarButtonStyle}"
                                Content="恢复为当前数据" />
                            <Button
                                Click="DeleteRun_Click"
                                IsEnabled="{x:Bind ViewModel.CanDeleteSelectedRun, Mode=OneWay}"
                                Style="{StaticResource ToolbarButtonStyle}"
                                Content="删除批次" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Page>
