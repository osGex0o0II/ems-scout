<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="EmsScout.Desktop.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Loaded="Page_Loaded"
    mc:Ignorable="d">

    <ScrollViewer>
        <StackPanel Padding="{StaticResource PagePadding}" Spacing="12">
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Spacing="3">
                    <TextBlock Style="{StaticResource WorkbenchPageTitleStyle}" Text="系统设置" />
                    <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="集中管理连接、目录、采集行为和界面偏好。" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                    <Button Command="{x:Bind ViewModel.SaveCommand}" Style="{StaticResource PrimaryToolbarButtonStyle}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon FontSize="14" Glyph="&#xE74E;" />
                            <TextBlock Text="保存设置" />
                        </StackPanel>
                    </Button>
                    <Button Command="{x:Bind ViewModel.ResetCommand}" Style="{StaticResource ToolbarButtonStyle}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon FontSize="14" Glyph="&#xE777;" />
                            <TextBlock Text="恢复默认" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>

            <Border
                Padding="12,8"
                Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                CornerRadius="6">
                <Grid ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <FontIcon
                        VerticalAlignment="Center"
                        FontSize="14"
                        Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                        Glyph="&#xE946;" />
                    <TextBlock
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="{x:Bind ViewModel.StatusText, Mode=OneWay}"
                        TextWrapping="WrapWholeWords" />
                </Grid>
            </Border>

            <Grid ColumnSpacing="14" RowSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Style="{StaticResource WorkbenchCardStyle}">
                    <StackPanel IsEnabled="{x:Bind ViewModel.CanEditCriticalSettings, Mode=OneWay}" Spacing="10">
                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="EMS 连接" />
                        <TextBox Header="EMS 地址" Text="{x:Bind ViewModel.EmsUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <NumberBox
                            Header="Edge CDP 端口"
                            LargeChange="100"
                            Minimum="1"
                            Maximum="65535"
                            SmallChange="1"
                            SpinButtonPlacementMode="Inline"
                            Value="{x:Bind ViewModel.EdgeCdpPort, Mode=TwoWay}" />
                        <ToggleSwitch Header="启动采集前检查登录态" IsOn="{x:Bind ViewModel.CheckLoginBeforeCollection, Mode=TwoWay}" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource WorkbenchCardStyle}">
                    <StackPanel IsEnabled="{x:Bind ViewModel.CanEditCriticalSettings, Mode=OneWay}" Spacing="10">
                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="目录" />
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox Header="数据目录" Text="{x:Bind ViewModel.DataDirectory, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <Button
                                Grid.Column="1"
                                VerticalAlignment="Bottom"
                                Click="PickDataDirectory_Click"
                                Style="{StaticResource ToolbarButtonStyle}"
                                ToolTipService.ToolTip="选择数据目录">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <SymbolIcon Symbol="OpenFile" />
                                    <TextBlock Text="选择" />
                                </StackPanel>
                            </Button>
                        </Grid>
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox Header="导出目录" Text="{x:Bind ViewModel.ExportDirectory, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <Button
                                Grid.Column="1"
                                VerticalAlignment="Bottom"
                                Click="PickExportDirectory_Click"
                                Style="{StaticResource ToolbarButtonStyle}"
                                ToolTipService.ToolTip="选择导出目录">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <SymbolIcon Symbol="OpenFile" />
                                    <TextBlock Text="选择" />
                                </StackPanel>
                            </Button>
                        </Grid>
                        <ToggleSwitch Header="跟踪最近 Excel 导出" IsOn="{x:Bind ViewModel.TrackRecentExports, Mode=TwoWay}" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Style="{StaticResource WorkbenchCardStyle}">
                    <StackPanel IsEnabled="{x:Bind ViewModel.CanEditCriticalSettings, Mode=OneWay}" Spacing="10">
                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="采集行为" />
                        <ComboBox Header="默认采集模式" SelectedIndex="{x:Bind ViewModel.DefaultCollectionModeIndex, Mode=TwoWay}">
                            <ComboBoxItem Content="Edge CDP" />
                            <ComboBoxItem Content="自动启动 Edge" />
                        </ComboBox>
                        <ComboBox Header="日志级别" SelectedIndex="{x:Bind ViewModel.LogLevelIndex, Mode=TwoWay}">
                            <ComboBoxItem Content="ERROR" />
                            <ComboBoxItem Content="INFO" />
                            <ComboBoxItem Content="DEBUG" />
                        </ComboBox>
                        <ToggleSwitch Header="保存 NDJSON 日志" IsOn="{x:Bind ViewModel.SaveNdjsonLog, Mode=TwoWay}" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource WorkbenchCardStyle}">
                    <StackPanel Spacing="10">
                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="外观" />
                        <ComboBox Header="主题" SelectedIndex="{x:Bind ViewModel.ThemeIndex, Mode=TwoWay}">
                            <ComboBoxItem Content="跟随系统" />
                            <ComboBoxItem Content="浅色" />
                            <ComboBoxItem Content="深色" />
                        </ComboBox>
                        <ToggleSwitch Header="紧凑数据表" IsOn="{x:Bind ViewModel.CompactDataTable, Mode=TwoWay}" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="2" Grid.ColumnSpan="2" Style="{StaticResource WorkbenchCardStyle}">
                    <Grid ColumnSpacing="12">
                        <StackPanel Spacing="4">
                            <TextBlock Style="{StaticResource SectionTitleStyle}" Text="高级" />
                            <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind ViewModel.SettingsPath, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                            <Button
                                HorizontalAlignment="Left"
                                Click="MigrateLegacyOut_Click"
                                IsEnabled="{x:Bind ViewModel.CanEditCriticalSettings, Mode=OneWay}"
                                Style="{StaticResource ToolbarButtonStyle}"
                                ToolTipService.ToolTip="选择旧 out 目录并迁移数据库和兼容数据">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <SymbolIcon Symbol="Upload" />
                                    <TextBlock Text="迁移旧数据" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</Page>
