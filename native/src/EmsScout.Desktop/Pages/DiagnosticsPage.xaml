<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="EmsScout.Desktop.Pages.DiagnosticsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Loaded="Page_Loaded"
    mc:Ignorable="d">

    <Grid Padding="{StaticResource PagePadding}" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Spacing="3">
                <TextBlock Style="{StaticResource WorkbenchPageTitleStyle}" Text="诊断" />
                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind ViewModel.StatusText, Mode=OneWay}" />
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                <Button Command="{x:Bind ViewModel.OpenWorkspaceCommand}" Style="{StaticResource ToolbarButtonStyle}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon FontSize="14" Glyph="&#xE838;" />
                        <TextBlock Text="工作区" />
                    </StackPanel>
                </Button>
                <Button Command="{x:Bind ViewModel.OpenDataDirectoryCommand}" Style="{StaticResource ToolbarButtonStyle}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon FontSize="14" Glyph="&#xE8B7;" />
                        <TextBlock Text="数据目录" />
                    </StackPanel>
                </Button>
                <Button Command="{x:Bind ViewModel.OpenExportDirectoryCommand}" Style="{StaticResource ToolbarButtonStyle}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon FontSize="14" Glyph="&#xE118;" />
                        <TextBlock Text="导出目录" />
                    </StackPanel>
                </Button>
                <Button Command="{x:Bind ViewModel.RefreshCommand}" Style="{StaticResource PrimaryToolbarButtonStyle}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon FontSize="14" Glyph="&#xE72C;" />
                        <TextBlock Text="刷新" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <InfoBar
            Grid.Row="1"
            IsClosable="False"
            IsOpen="True"
            Severity="Informational"
            Title="当前主流程"
            Message="原生应用只暴露数据管理筛选后的 Excel 导出；旧 Web 面板和多格式报表脚本保留为 legacy 工具，不进入当前 UI 主流程。" />

        <Grid Grid.Row="2" ColumnSpacing="14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.95*" MinWidth="420" />
                <ColumnDefinition Width="1.35*" MinWidth="560" />
            </Grid.ColumnDefinitions>

            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="12">
                    <Border Style="{StaticResource WorkbenchCardStyle}">
                        <StackPanel Spacing="10">
                            <TextBlock Style="{StaticResource SectionTitleStyle}" Text="应用信息" />
                            <ItemsControl ItemsSource="{x:Bind ViewModel.AppRows, Mode=OneWay}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,7" ColumnSpacing="10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="86" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{Binding Label}" />
                                            <StackPanel Grid.Column="1" Spacing="1">
                                                <TextBlock FontWeight="SemiBold" Text="{Binding Value}" TextWrapping="WrapWholeWords" />
                                                <TextBlock Foreground="{ThemeResource TextFillColorTertiaryBrush}" Text="{Binding Detail}" TextWrapping="WrapWholeWords" />
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource WorkbenchCardStyle}">
                        <StackPanel Spacing="10">
                            <TextBlock Style="{StaticResource SectionTitleStyle}" Text="路径检查" />
                            <ItemsControl ItemsSource="{x:Bind ViewModel.PathRows, Mode=OneWay}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,7" ColumnSpacing="10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="86" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="54" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{Binding Label}" />
                                            <TextBlock Grid.Column="1" FontWeight="SemiBold" Text="{Binding Value}" TextWrapping="WrapWholeWords" />
                                            <TextBlock Grid.Column="2" Foreground="{ThemeResource TextFillColorTertiaryBrush}" Text="{Binding Detail}" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource WorkbenchCardStyle}">
                        <StackPanel Spacing="10">
                            <TextBlock Style="{StaticResource SectionTitleStyle}" Text="流程口径" />
                            <ItemsControl ItemsSource="{x:Bind ViewModel.WorkflowRows, Mode=OneWay}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,7" ColumnSpacing="10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="106" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{Binding Label}" />
                                            <StackPanel Grid.Column="1" Spacing="1">
                                                <TextBlock FontWeight="SemiBold" Text="{Binding Value}" TextWrapping="WrapWholeWords" />
                                                <TextBlock Foreground="{ThemeResource TextFillColorTertiaryBrush}" Text="{Binding Detail}" TextWrapping="WrapWholeWords" />
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <Grid Grid.Column="1" RowSpacing="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="1.1*" />
                    <RowDefinition Height="0.9*" />
                </Grid.RowDefinitions>

                <Border Style="{StaticResource WorkbenchCardStyle}">
                    <Grid RowSpacing="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="2">
                                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="日志查看" />
                                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="读取最近枚举、任务和桌面日志，便于排查采集、导入和原生启动问题。" TextWrapping="WrapWholeWords" />
                            </StackPanel>
                            <Button Grid.Column="1" Command="{x:Bind ViewModel.OpenSelectedLogCommand}" Style="{StaticResource ToolbarButtonStyle}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon FontSize="14" Glyph="&#xE8A7;" />
                                    <TextBlock Text="定位日志" />
                                </StackPanel>
                            </Button>
                        </Grid>

                        <Grid Grid.Row="1" ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="0.95*" />
                                <ColumnDefinition Width="1.15*" />
                            </Grid.ColumnDefinitions>
                            <ListView
                                ItemsSource="{x:Bind ViewModel.LogFiles, Mode=OneWay}"
                                SelectedItem="{x:Bind ViewModel.SelectedLog, Mode=TwoWay}"
                                SelectionMode="Single">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Padding="0,5" Spacing="2">
                                            <TextBlock FontWeight="SemiBold" Text="{Binding Name}" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{Binding Summary}" />
                                            <TextBlock Foreground="{ThemeResource TextFillColorTertiaryBrush}" Text="{Binding RelativePath}" TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>

                            <Grid Grid.Column="1" RowSpacing="6">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <TextBlock FontWeight="SemiBold" Text="{x:Bind ViewModel.PreviewTitle, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                                    <TextBlock
                                        FontFamily="Consolas"
                                        FontSize="12"
                                        IsTextSelectionEnabled="True"
                                        Text="{x:Bind ViewModel.PreviewText, Mode=OneWay}"
                                        TextWrapping="NoWrap" />
                                </ScrollViewer>
                            </Grid>
                        </Grid>
                    </Grid>
                </Border>

                <Border Grid.Row="1" Style="{StaticResource WorkbenchCardStyle}">
                    <Grid RowSpacing="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <StackPanel Spacing="2">
                            <TextBlock Style="{StaticResource SectionTitleStyle}" Text="最近 Excel" />
                            <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="只展示数据管理筛选导出的 Excel 文件，不提供旧报表生成入口。" TextWrapping="WrapWholeWords" />
                        </StackPanel>
                        <ListView
                            Grid.Row="1"
                            ItemsSource="{x:Bind ViewModel.RecentExports, Mode=OneWay}"
                            SelectionMode="None">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Padding="0,5" ColumnSpacing="10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Spacing="2">
                                            <TextBlock FontWeight="SemiBold" Text="{Binding Name}" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{Binding Summary}" />
                                            <TextBlock Foreground="{ThemeResource TextFillColorTertiaryBrush}" Text="{Binding RelativePath}" TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                        <Button
                                            Grid.Column="1"
                                            Click="OpenRecentExport_Click"
                                            Style="{StaticResource ToolbarButtonStyle}"
                                            Tag="{Binding}"
                                            ToolTipService.ToolTip="打开导出位置">
                                            <FontIcon FontSize="14" Glyph="&#xE838;" />
                                        </Button>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Page>
