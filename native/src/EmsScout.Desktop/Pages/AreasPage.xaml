<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="EmsScout.Desktop.Pages.AreasPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:EmsScout.Desktop.ViewModels"
    Loaded="Page_Loaded"
    mc:Ignorable="d">
    <Grid Padding="{StaticResource PagePadding}" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Spacing="3">
                <TextBlock Style="{StaticResource WorkbenchPageTitleStyle}" Text="规则与计划" />
                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind ViewModel.StatusText, Mode=OneWay}" />
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                <Button
                    AutomationProperties.Name="新建分组"
                    Command="{x:Bind ViewModel.NewGroupCommand}"
                    Style="{StaticResource PrimaryToolbarButtonStyle}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon FontSize="14" Glyph="&#xE710;" />
                        <TextBlock Text="新建分组" />
                    </StackPanel>
                </Button>
                <Button
                    AutomationProperties.Name="刷新"
                    Command="{x:Bind ViewModel.RefreshCommand}"
                    Style="{StaticResource ToolbarButtonStyle}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon FontSize="14" Glyph="&#xE72C;" />
                        <TextBlock Text="刷新" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <InfoBar
            Grid.Row="1"
            IsClosable="False"
            IsOpen="True"
            Severity="Informational"
            Title="{x:Bind ViewModel.GroupEditorTitle, Mode=OneWay}"
            Message="{x:Bind ViewModel.GroupEditorMessage, Mode=OneWay}" />

        <Grid Grid.Row="2" ColumnSpacing="14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360" MinWidth="280" />
                <ColumnDefinition Width="*" MinWidth="620" />
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource WorkbenchCardStyle}" Padding="0">
                <Grid RowSpacing="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Padding="16,14,16,8" Spacing="2">
                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="区域组" />
                        <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="系统规则和自定义分组统一管理。" TextWrapping="WrapWholeWords" />
                    </StackPanel>
                    <Grid Grid.Row="1">
                        <ListView
                            ItemsSource="{x:Bind ViewModel.Groups, Mode=OneWay}"
                            SelectedItem="{x:Bind ViewModel.SelectedGroup, Mode=TwoWay}"
                            SelectionChanged="GroupList_SelectionChanged"
                            SelectionMode="Single">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="vm:GroupSummaryRow">
                                    <Grid Padding="16,9" ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Spacing="3">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <TextBlock FontWeight="SemiBold" Text="{x:Bind Name}" />
                                                <TextBlock Foreground="{ThemeResource TextFillColorTertiaryBrush}" Text="{x:Bind Kind}" />
                                                <TextBlock Foreground="{ThemeResource TextFillColorTertiaryBrush}" Text="{x:Bind StateLabel}" />
                                            </StackPanel>
                                            <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind Description}" TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" HorizontalAlignment="Right" Spacing="2">
                                            <TextBlock HorizontalAlignment="Right" FontWeight="SemiBold" Text="{x:Bind CountText}" />
                                            <TextBlock HorizontalAlignment="Right" Foreground="{ThemeResource TextFillColorTertiaryBrush}" Text="{x:Bind ItemCountText}" />
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                        <StackPanel
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Spacing="8"
                            Visibility="{x:Bind ViewModel.LoadingStateVisibility, Mode=OneWay}">
                            <ProgressRing
                                Width="28"
                                Height="28"
                                IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}" />
                            <TextBlock
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="正在计算分组命中数量" />
                        </StackPanel>
                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                            Text="暂无区域组"
                            Visibility="{x:Bind ViewModel.GroupListEmptyVisibility, Mode=OneWay}" />
                    </Grid>
                </Grid>
            </Border>

            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="12">
                    <Border Style="{StaticResource WorkbenchCardStyle}">
                        <StackPanel Spacing="12">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="2">
                                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="{x:Bind ViewModel.GroupEditorTitle, Mode=OneWay}" />
                                    <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind ViewModel.SelectedGroup.Description, Mode=OneWay, FallbackValue='保存分组后即可维护成员'}" TextWrapping="WrapWholeWords" />
                                </StackPanel>
                                <Button
                                    AutomationProperties.Name="数据管理"
                                    Grid.Column="1"
                                    Click="OpenInData_Click"
                                    IsEnabled="{x:Bind ViewModel.CanOpenSelectedInData, Mode=OneWay}"
                                    Style="{StaticResource ToolbarButtonStyle}">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon FontSize="14" Glyph="&#xE8A5;" />
                                        <TextBlock Text="数据管理" />
                                    </StackPanel>
                                </Button>
                            </Grid>

                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Padding="10" Background="{ThemeResource ControlFillColorDefaultBrush}" CornerRadius="6">
                                    <StackPanel Spacing="2">
                                        <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="命中设备" />
                                        <TextBlock FontWeight="SemiBold" Text="{x:Bind ViewModel.SelectedGroup.CountText, Mode=OneWay, FallbackValue='--'}" />
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="1" Padding="10" Background="{ThemeResource ControlFillColorDefaultBrush}" CornerRadius="6">
                                    <StackPanel Spacing="2">
                                        <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="成员" />
                                        <TextBlock FontWeight="SemiBold" Text="{x:Bind ViewModel.SelectedGroup.ItemCountText, Mode=OneWay, FallbackValue='--'}" />
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="2" Padding="10" Background="{ThemeResource ControlFillColorDefaultBrush}" CornerRadius="6">
                                    <StackPanel Spacing="2">
                                        <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="开机" />
                                        <TextBlock FontWeight="SemiBold" Text="{x:Bind ViewModel.SelectedGroup.OnCount, Mode=OneWay, FallbackValue=0}" />
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="3" Padding="10" Background="{ThemeResource ControlFillColorDefaultBrush}" CornerRadius="6">
                                    <StackPanel Spacing="2">
                                        <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="离线" />
                                        <TextBlock FontWeight="SemiBold" Text="{x:Bind ViewModel.SelectedGroup.OfflineCount, Mode=OneWay, FallbackValue=0}" />
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="4" Padding="10" Background="{ThemeResource ControlFillColorDefaultBrush}" CornerRadius="6">
                                    <StackPanel Spacing="2">
                                        <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="覆盖子区" />
                                        <TextBlock FontWeight="SemiBold" Text="{x:Bind ViewModel.SelectedGroup.CoveredAreas, Mode=OneWay, FallbackValue=0}" />
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <StackPanel Visibility="{x:Bind ViewModel.CustomEditorVisibility, Mode=OneWay}" Spacing="10">
                                <Grid ColumnSpacing="8" RowSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1.2*" />
                                        <ColumnDefinition Width="1*" />
                                        <ColumnDefinition Width="0.8*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBox Header="区域组名" Text="{x:Bind ViewModel.EditName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBox Grid.Column="1" Header="用途标签" PlaceholderText="巡检 / 装修 / 未交付" Text="{x:Bind ViewModel.EditAreaLabel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <ComboBox
                                        Grid.Column="2"
                                        Header="级别"
                                        SelectedValue="{x:Bind ViewModel.EditPriority, Mode=TwoWay}"
                                        SelectedValuePath="Content">
                                        <ComboBoxItem Content="普通" />
                                        <ComboBoxItem Content="重点" />
                                        <ComboBoxItem Content="紧急" />
                                    </ComboBox>
                                    <ToggleSwitch Grid.Column="3" Header="启用" IsOn="{x:Bind ViewModel.EditEnabled, Mode=TwoWay}" />
                                    <TextBox
                                        Grid.Row="1"
                                        Grid.ColumnSpan="4"
                                        Header="说明"
                                        AcceptsReturn="True"
                                        MinHeight="58"
                                        Text="{x:Bind ViewModel.EditDescription, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </Grid>

                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Button
                                        AutomationProperties.Name="保存分组"
                                        Command="{x:Bind ViewModel.SaveGroupCommand}"
                                        Style="{StaticResource PrimaryToolbarButtonStyle}">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <FontIcon FontSize="14" Glyph="&#xE74E;" />
                                            <TextBlock Text="保存分组" />
                                        </StackPanel>
                                    </Button>
                                    <Button
                                        AutomationProperties.Name="删除分组"
                                        Click="DeleteGroup_Click"
                                        IsEnabled="{x:Bind ViewModel.CanDeleteSelectedGroup, Mode=OneWay}"
                                        Style="{StaticResource ToolbarButtonStyle}">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <FontIcon FontSize="14" Glyph="&#xE74D;" />
                                            <TextBlock Text="删除分组" />
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Visibility="{x:Bind ViewModel.SystemEditorVisibility, Mode=OneWay}" Spacing="8">
                                <TextBlock FontWeight="SemiBold" Text="{x:Bind ViewModel.SelectedGroup.Kind, Mode=OneWay, FallbackValue='系统区域'}" />
                                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind ViewModel.GroupEditorMessage, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource WorkbenchCardStyle}">
                        <StackPanel Spacing="10">
                            <StackPanel Spacing="2">
                                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="楼层候选目录" />
                                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="这里只维护成员编辑器可选的楼层候选，不会把楼层加入当前分组；加入分组请在下方“成员维护”中新增楼层成员。" TextWrapping="WrapWholeWords" />
                            </StackPanel>

                            <Grid ColumnSpacing="8" RowSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140" />
                                    <ColumnDefinition Width="140" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <ComboBox
                                    Header="楼栋"
                                    ItemsSource="{x:Bind ViewModel.BuildingOptions, Mode=OneWay}"
                                    SelectedItem="{x:Bind ViewModel.FloorCatalogBuilding, Mode=TwoWay}" />
                                <TextBox
                                    Grid.Column="1"
                                    Header="楼层"
                                    PlaceholderText="1F / B1F / 2.5F"
                                    Text="{x:Bind ViewModel.FloorCatalogLabel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBox
                                    Grid.Column="2"
                                    Header="备注"
                                    PlaceholderText="人工新增楼层目录"
                                    Text="{x:Bind ViewModel.FloorCatalogNote, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <Button
                                    AutomationProperties.Name="保存楼层"
                                    Grid.Column="3"
                                    VerticalAlignment="Bottom"
                                    Command="{x:Bind ViewModel.SaveFloorCommand}"
                                    Style="{StaticResource PrimaryToolbarButtonStyle}">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon FontSize="14" Glyph="&#xE74E;" />
                                        <TextBlock Text="保存楼层" />
                                    </StackPanel>
                                </Button>
                                <Button
                                    AutomationProperties.Name="删除楼层"
                                    Grid.Column="4"
                                    VerticalAlignment="Bottom"
                                    Click="DeleteFloor_Click"
                                    IsEnabled="{x:Bind ViewModel.CanDeleteSelectedFloor, Mode=OneWay}"
                                    Style="{StaticResource ToolbarButtonStyle}">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon FontSize="14" Glyph="&#xE74D;" />
                                        <TextBlock Text="停用楼层" />
                                    </StackPanel>
                                </Button>
                            </Grid>

                            <ListView
                                MaxHeight="150"
                                ItemsSource="{x:Bind ViewModel.FloorCatalog, Mode=OneWay}"
                                SelectedItem="{x:Bind ViewModel.SelectedFloorCatalog, Mode=TwoWay}"
                                SelectionMode="Single">
                                <ListView.Header>
                                    <Grid Padding="0,0,0,6" ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="90" />
                                            <ColumnDefinition Width="90" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock FontWeight="SemiBold" Text="楼层" />
                                        <TextBlock Grid.Column="1" FontWeight="SemiBold" Text="来源" />
                                        <TextBlock Grid.Column="2" FontWeight="SemiBold" Text="状态" />
                                        <TextBlock Grid.Column="3" FontWeight="SemiBold" Text="备注" />
                                    </Grid>
                                </ListView.Header>
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="vm:FloorCatalogRow">
                                        <Grid Padding="0,5" ColumnSpacing="12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="120" />
                                                <ColumnDefinition Width="90" />
                                                <ColumnDefinition Width="90" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock FontWeight="SemiBold" Text="{x:Bind FloorLabel}" />
                                            <TextBlock Grid.Column="1" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind Source}" />
                                            <TextBlock Grid.Column="2" Text="{x:Bind StateLabel}" />
                                            <TextBlock Grid.Column="3" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind Note}" TextWrapping="WrapWholeWords" />
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource WorkbenchCardStyle}">
                        <StackPanel Spacing="10">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="2">
                                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="{x:Bind ViewModel.MemberEditorTitle, Mode=OneWay}" />
                                    <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind ViewModel.MemberEditorMessage, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                                </StackPanel>
                                <Button
                                    AutomationProperties.Name="新增成员"
                                    Grid.Column="1"
                                    Command="{x:Bind ViewModel.BeginAddMemberCommand}"
                                    IsEnabled="{x:Bind ViewModel.CanBeginAddMember, Mode=OneWay}"
                                    Style="{StaticResource PrimaryToolbarButtonStyle}">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon FontSize="14" Glyph="&#xE710;" />
                                        <TextBlock Text="新增成员" />
                                    </StackPanel>
                                </Button>
                            </Grid>

                            <Grid ColumnSpacing="8" RowSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1*" MinWidth="130" />
                                    <ColumnDefinition Width="1*" MinWidth="130" />
                                    <ColumnDefinition Width="1*" MinWidth="130" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <ComboBox
                                    Header="范围类型"
                                    DisplayMemberPath="Label"
                                    IsEnabled="{x:Bind ViewModel.CanEditMemberTarget, Mode=OneWay}"
                                    ItemsSource="{x:Bind ViewModel.TargetTypes, Mode=OneWay}"
                                    SelectedItem="{x:Bind ViewModel.SelectedTargetType, Mode=TwoWay}" />
                                <ComboBox
                                    Grid.Column="1"
                                    Header="楼栋"
                                    IsEnabled="{x:Bind ViewModel.CanEditMemberTarget, Mode=OneWay}"
                                    ItemsSource="{x:Bind ViewModel.BuildingOptions, Mode=OneWay}"
                                    SelectedItem="{x:Bind ViewModel.TargetBuilding, Mode=TwoWay}" />
                                <ComboBox
                                    Grid.Column="2"
                                    Header="楼层"
                                    DisplayMemberPath="DisplayLabel"
                                    IsEnabled="{x:Bind ViewModel.CanEditMemberTarget, Mode=OneWay}"
                                    ItemsSource="{x:Bind ViewModel.FloorOptions, Mode=OneWay}"
                                    SelectedValuePath="Value"
                                    SelectedValue="{x:Bind ViewModel.TargetFloor, Mode=TwoWay}" />
                                <Button
                                    AutomationProperties.Name="加载候选"
                                    Grid.Column="3"
                                    VerticalAlignment="Bottom"
                                    Command="{x:Bind ViewModel.LoadTargetOptionsCommand}"
                                    IsEnabled="{x:Bind ViewModel.CanLoadMemberOptions, Mode=OneWay}"
                                    Style="{StaticResource ToolbarButtonStyle}">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon FontSize="14" Glyph="&#xE8B7;" />
                                        <TextBlock Text="加载候选" />
                                    </StackPanel>
                                </Button>
                                <TextBox
                                    Grid.Row="1"
                                    Grid.ColumnSpan="4"
                                    Header="搜索候选"
                                    IsEnabled="{x:Bind ViewModel.CanSearchMemberOptions, Mode=OneWay}"
                                    PlaceholderText="输入设备名、子区或楼层"
                                    Text="{x:Bind ViewModel.TargetOptionSearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <ComboBox
                                    Grid.Row="2"
                                    Grid.ColumnSpan="4"
                                    Header="候选子区或设备"
                                    DisplayMemberPath="Label"
                                    IsEnabled="{x:Bind ViewModel.CanSelectMemberOption, Mode=OneWay}"
                                    ItemsSource="{x:Bind ViewModel.TargetOptions, Mode=OneWay}"
                                    SelectedItem="{x:Bind ViewModel.SelectedTargetOption, Mode=TwoWay}" />
                                <TextBox
                                    Grid.Row="3"
                                    Grid.ColumnSpan="2"
                                    Header="备注"
                                    IsEnabled="{x:Bind ViewModel.CanEditMemberTarget, Mode=OneWay}"
                                    PlaceholderText="可填写巡检原因或临时状态"
                                    Text="{x:Bind ViewModel.TargetNote, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <StackPanel Grid.Row="3" Grid.Column="2" Grid.ColumnSpan="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Bottom">
                                    <Button
                                        AutomationProperties.Name="保存成员"
                                        Command="{x:Bind ViewModel.SaveMemberDraftCommand}"
                                        IsEnabled="{x:Bind ViewModel.CanSaveMemberDraft, Mode=OneWay}"
                                        Style="{StaticResource PrimaryToolbarButtonStyle}">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <FontIcon FontSize="14" Glyph="&#xE74E;" />
                                            <TextBlock Text="{x:Bind ViewModel.MemberSaveButtonText, Mode=OneWay}" />
                                        </StackPanel>
                                    </Button>
                                    <Button
                                        AutomationProperties.Name="取消成员编辑"
                                        Command="{x:Bind ViewModel.CancelMemberDraftCommand}"
                                        IsEnabled="{x:Bind ViewModel.CanCancelMemberDraft, Mode=OneWay}"
                                        Style="{StaticResource ToolbarButtonStyle}">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <FontIcon FontSize="14" Glyph="&#xE711;" />
                                            <TextBlock Text="取消" />
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </Grid>

                            <TextBlock
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="{x:Bind ViewModel.MemberTargetPreview, Mode=OneWay}"
                                TextWrapping="WrapWholeWords" />
                            <TextBlock
                                Foreground="{ThemeResource SystemFillColorCautionBrush}"
                                Text="{x:Bind ViewModel.MemberConflictMessage, Mode=OneWay}"
                                TextWrapping="WrapWholeWords"
                                Visibility="{x:Bind ViewModel.MemberConflictVisibility, Mode=OneWay}" />

                            <ListView
                                MaxHeight="220"
                                IsEnabled="{x:Bind ViewModel.CanOperateMemberRows, Mode=OneWay}"
                                ItemsSource="{x:Bind ViewModel.Items, Mode=OneWay}"
                                SelectedItem="{x:Bind ViewModel.SelectedItem, Mode=TwoWay}"
                                SelectionMode="Single">
                                <ListView.Header>
                                    <Grid Padding="0,0,0,6" ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="96" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="1.2*" />
                                            <ColumnDefinition Width="132" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock FontWeight="SemiBold" Text="类型" />
                                        <TextBlock Grid.Column="1" FontWeight="SemiBold" Text="对象" />
                                        <TextBlock Grid.Column="2" FontWeight="SemiBold" Text="备注" />
                                        <TextBlock Grid.Column="3" FontWeight="SemiBold" Text="操作" />
                                    </Grid>
                                </ListView.Header>
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="vm:AreaGroupItemRow">
                                        <Grid Padding="0,5" ColumnSpacing="12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="96" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="1.2*" />
                                                <ColumnDefinition Width="132" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock FontWeight="SemiBold" Text="{x:Bind TargetTypeLabel}" />
                                            <TextBlock Grid.Column="1" Text="{x:Bind TargetLabel}" TextWrapping="WrapWholeWords" />
                                            <TextBlock Grid.Column="2" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind Note}" TextWrapping="WrapWholeWords" />
                                            <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="6">
                                                <Button
                                                    AutomationProperties.Name="编辑成员"
                                                    Click="EditItem_Click"
                                                    Style="{StaticResource ToolbarButtonStyle}">
                                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                                        <FontIcon FontSize="14" Glyph="&#xE70F;" />
                                                        <TextBlock Text="编辑" />
                                                    </StackPanel>
                                                </Button>
                                                <Button
                                                    AutomationProperties.Name="删除成员"
                                                    Click="DeleteItem_Click"
                                                    Style="{StaticResource ToolbarButtonStyle}">
                                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                                        <FontIcon FontSize="14" Glyph="&#xE74D;" />
                                                        <TextBlock Text="删除" />
                                                    </StackPanel>
                                                </Button>
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource WorkbenchCardStyle}">
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <StackPanel Spacing="3">
                                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="日期计划" />
                                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="日期和启用时段已移到独立的“日期管理”；请先在这里维护区域组成员，再到月历中批量设置日期。" TextWrapping="WrapWholeWords" />
                            </StackPanel>
                            <Button Grid.Column="1" Click="OpenDateManagement_Click" Style="{StaticResource PrimaryToolbarButtonStyle}" Content="打开日期管理" />
                        </Grid>
                    </Border>

                    <!-- Legacy inline schedule editor intentionally retired; date planning now has its own page.
                    <Border Visibility="Collapsed" Style="{StaticResource WorkbenchCardStyle}">
                        <StackPanel Spacing="10">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="2">
                                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="时间组" />
