                        </StackPanel>
                    </Border>

                    -->
                    <Border Style="{StaticResource WorkbenchCardStyle}">
                        <StackPanel Spacing="10">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="2">
                                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="{x:Bind ViewModel.WatchEditorTitle, Mode=OneWay}" />
                                    <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind ViewModel.WatchEditorMessage, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                                    <TextBlock Foreground="{ThemeResource TextFillColorTertiaryBrush}" Text="{x:Bind ViewModel.WatchSummaryText, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                                </StackPanel>
                                <ToggleSwitch
                                    Grid.Column="1"
                                    Header="启用"
                                    IsEnabled="{x:Bind ViewModel.CanMaintainWatch, Mode=OneWay}"
                                    IsOn="{x:Bind ViewModel.WatchEnabled, Mode=TwoWay}" />
                            </Grid>

                            <Grid ColumnSpacing="10" RowSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1*" />
                                    <ColumnDefinition Width="1*" />
                                    <ColumnDefinition Width="1*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBox
                                    Grid.ColumnSpan="3"
                                    Header="规则名称"
                                    IsEnabled="{x:Bind ViewModel.CanMaintainWatch, Mode=OneWay}"
                                    Text="{x:Bind ViewModel.WatchName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <DatePicker
                                    Grid.Row="1"
                                    Header="开始日期"
                                    IsEnabled="{x:Bind ViewModel.CanMaintainWatch, Mode=OneWay}"
                                    Date="{x:Bind ViewModel.WatchStartDate, Mode=TwoWay}" />
                                <TimePicker
                                    Grid.Row="1"
                                    Grid.Column="1"
                                    Header="开始时间"
                                    ClockIdentifier="24HourClock"
                                    IsEnabled="{x:Bind ViewModel.CanMaintainWatch, Mode=OneWay}"
                                    Time="{x:Bind ViewModel.WatchStartTime, Mode=TwoWay}" />
                                <DatePicker
                                    Grid.Row="2"
                                    Header="结束日期"
                                    IsEnabled="{x:Bind ViewModel.CanMaintainWatch, Mode=OneWay}"
                                    Date="{x:Bind ViewModel.WatchEndDate, Mode=TwoWay}" />
                                <TimePicker
                                    Grid.Row="2"
                                    Grid.Column="1"
                                    Header="结束时间"
                                    ClockIdentifier="24HourClock"
                                    IsEnabled="{x:Bind ViewModel.CanMaintainWatch, Mode=OneWay}"
                                    Time="{x:Bind ViewModel.WatchEndTime, Mode=TwoWay}" />
                            </Grid>
                            <TextBlock
                                Foreground="{ThemeResource SystemFillColorCautionBrush}"
                                Text="{x:Bind ViewModel.WatchTimeValidationMessage, Mode=OneWay}"
                                Visibility="{x:Bind ViewModel.WatchTimeValidationVisibility, Mode=OneWay}" />

                            <TextBox
                                Header="关注说明"
                                AcceptsReturn="True"
                                MinHeight="54"
                                IsEnabled="{x:Bind ViewModel.CanMaintainWatch, Mode=OneWay}"
                                Text="{x:Bind ViewModel.WatchNote, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button
                                    AutomationProperties.Name="保存关注"
                                    Command="{x:Bind ViewModel.SaveWatchCommand}"
                                    Style="{StaticResource PrimaryToolbarButtonStyle}">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon FontSize="14" Glyph="&#xE74E;" />
                                        <TextBlock Text="保存关注" />
                                    </StackPanel>
                                </Button>
                                <Button
                                    AutomationProperties.Name="删除关注"
                                    Click="DeleteWatch_Click"
                                    IsEnabled="{x:Bind ViewModel.CanDeleteSelectedWatch, Mode=OneWay}"
                                    Style="{StaticResource ToolbarButtonStyle}">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon FontSize="14" Glyph="&#xE74D;" />
                                        <TextBlock Text="删除关注" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>

                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="2">
                                    <TextBlock FontWeight="SemiBold" Text="关注事件" />
                                    <TextBlock Foreground="{ThemeResource TextFillColorTertiaryBrush}" Text="{x:Bind ViewModel.WatchIncidentSummary, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                                </StackPanel>
                                <Button
                                    AutomationProperties.Name="查看关注异常"
                                    Grid.Column="1"
                                    Click="OpenWatchIncident_Click"
                                    IsEnabled="{x:Bind ViewModel.CanOpenSelectedWatchIncident, Mode=OneWay}"
                                    Style="{StaticResource ToolbarButtonStyle}">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon FontSize="14" Glyph="&#xE8A5;" />
                                        <TextBlock Text="查看异常" />
                                    </StackPanel>
                                </Button>
                            </Grid>

                            <Grid>
                                <ListView
                                    MaxHeight="188"
                                    ItemsSource="{x:Bind ViewModel.WatchIncidents, Mode=OneWay}"
                                    SelectedItem="{x:Bind ViewModel.SelectedWatchIncident, Mode=TwoWay}"
                                    SelectionMode="Single">
                                    <ListView.Header>
                                        <Grid Padding="0,0,0,6" ColumnSpacing="10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="1.25*" />
                                                <ColumnDefinition Width="0.8*" />
                                                <ColumnDefinition Width="1*" />
                                                <ColumnDefinition Width="0.8*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock FontWeight="SemiBold" Text="设备" />
                                            <TextBlock Grid.Column="1" FontWeight="SemiBold" Text="变化" />
                                            <TextBlock Grid.Column="2" FontWeight="SemiBold" Text="时间" />
                                            <TextBlock Grid.Column="3" FontWeight="SemiBold" Text="批次" />
                                        </Grid>
                                    </ListView.Header>
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Padding="0,5" ColumnSpacing="10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="1.25*" />
                                                    <ColumnDefinition Width="0.8*" />
                                                    <ColumnDefinition Width="1*" />
                                                    <ColumnDefinition Width="0.8*" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Spacing="1">
                                                    <TextBlock FontWeight="SemiBold" Text="{Binding DeviceName}" TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{Binding Location}" TextTrimming="CharacterEllipsis" />
                                                </StackPanel>
                                                <TextBlock Grid.Column="1" FontWeight="SemiBold" Text="{Binding ChangeText}" />
                                                <TextBlock Grid.Column="2" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{Binding TimeText}" />
                                                <TextBlock Grid.Column="3" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{Binding RunText}" />
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                    Text="暂无关注事件"
                                    Visibility="{x:Bind ViewModel.WatchIncidentEmptyVisibility, Mode=OneWay}" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource WorkbenchCardStyle}">
                        <Grid RowSpacing="8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock Style="{StaticResource SectionTitleStyle}" Text="系统规则说明" />
                            <ListView
                                Grid.Row="1"
                                MaxHeight="150"
                                ItemsSource="{x:Bind ViewModel.Rules, Mode=OneWay}"
                                SelectionMode="None">
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="vm:GroupRuleRow">
                                        <Grid Padding="0,5" ColumnSpacing="12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="1.1*" />
                                                <ColumnDefinition Width="2*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock FontWeight="SemiBold" Text="{x:Bind Title}" TextWrapping="WrapWholeWords" />
                                            <TextBlock Grid.Column="1" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind Description}" TextWrapping="WrapWholeWords" />
                                            <TextBlock Grid.Column="2" Foreground="{ThemeResource TextFillColorTertiaryBrush}" Text="{x:Bind Effect}" />
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Grid>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>
