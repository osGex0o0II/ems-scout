<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="EmsScout.Desktop.Pages.AreasPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:groups="using:EmsScout.Application.Groups"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:EmsScout.Desktop.ViewModels"
    Loaded="Page_Loaded"
    mc:Ignorable="d">
    <Grid Padding="{StaticResource PagePadding}" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Spacing="3">
                <TextBlock Style="{StaticResource WorkbenchPageTitleStyle}" Text="区域组" />
                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind ViewModel.StatusText, Mode=OneWay}" />
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                <Button AutomationProperties.Name="新建区域组" Command="{x:Bind ViewModel.NewGroupCommand}" Style="{StaticResource PrimaryToolbarButtonStyle}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon FontSize="14" Glyph="&#xE710;" />
                        <TextBlock Text="新建区域组" />
                    </StackPanel>
                </Button>
                <Button AutomationProperties.Name="刷新区域组" Command="{x:Bind ViewModel.RefreshCommand}" Style="{StaticResource ToolbarButtonStyle}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon FontSize="14" Glyph="&#xE72C;" />
                        <TextBlock Text="刷新" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <InfoBar
            Grid.Row="1"
            IsClosable="False"
            IsOpen="True"
            Severity="Informational"
            Title="规则匹配只产生待确认变更"
            Message="公区、非公区与自建组都可改名、停用或删除。采集后匹配到的加入/移除会进入审计，本页只显示提醒。" />

        <Grid x:Name="MasterDetailGrid" Grid.Row="2" ColumnSpacing="14">
            <VisualStateManager.VisualStateGroups>
                <VisualStateGroup x:Name="AreaLayoutStates">
                    <VisualState x:Name="NarrowAreaLayout">
                        <VisualState.StateTriggers>
                            <AdaptiveTrigger MinWindowWidth="0" />
                        </VisualState.StateTriggers>
                        <VisualState.Setters>
                            <Setter Target="GroupListColumn.Width" Value="240" />
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="WideAreaLayout">
                        <VisualState.StateTriggers>
                            <AdaptiveTrigger MinWindowWidth="1100" />
                        </VisualState.StateTriggers>
                        <VisualState.Setters>
                            <Setter Target="GroupListColumn.Width" Value="280" />
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateManager.VisualStateGroups>
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="GroupListColumn" Width="280" MinWidth="220" />
                <ColumnDefinition x:Name="DetailColumn" Width="*" />
            </Grid.ColumnDefinitions>

            <Border Padding="0" Style="{StaticResource WorkbenchCardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Padding="16,14,16,8" Spacing="3">
                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="区域组" />
                        <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="预设组与自建组统一维护。" />
                    </StackPanel>
                    <ListView
                        Grid.Row="1"
                        ItemsSource="{x:Bind ViewModel.Groups, Mode=OneWay}"
                        SelectedItem="{x:Bind ViewModel.SelectedGroup, Mode=TwoWay}"
                        SelectionMode="Single">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="vm:GroupSummaryRow">
                                <Grid Padding="14,9" ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Spacing="3">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock FontWeight="SemiBold" Text="{x:Bind Name}" />
                                            <TextBlock Foreground="{ThemeResource TextFillColorTertiaryBrush}" Text="{x:Bind StateLabel}" />
                                        </StackPanel>
                                        <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind Description}" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" HorizontalAlignment="Right" Spacing="2">
                                        <TextBlock HorizontalAlignment="Right" FontWeight="SemiBold" Text="{x:Bind CountText}" />
                                        <TextBlock HorizontalAlignment="Right" Foreground="{ThemeResource TextFillColorTertiaryBrush}" Text="正式成员" />
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <ScrollViewer
                x:Name="DetailScrollViewer"
                Grid.Column="1"
                HorizontalScrollBarVisibility="Disabled"
                HorizontalScrollMode="Disabled"
                VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="12">
                    <Border Style="{StaticResource WorkbenchCardStyle}">
                        <StackPanel Spacing="12">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="2">
                                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="{x:Bind ViewModel.GroupEditorTitle, Mode=OneWay}" />
                                    <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="名称、状态和说明均可随时调整。" />
                                </StackPanel>
                                <Button
                                    x:Name="OpenAuditButton"
                                    Grid.Column="1"
                                    AutomationProperties.Name="打开分组审计"
                                    Click="NavigateToAudit_Click"
                                    Style="{StaticResource ToolbarButtonStyle}">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon FontSize="14" Glyph="&#xE9D9;" />
                                        <TextBlock Text="打开审计" />
                                    </StackPanel>
                                </Button>
                            </Grid>
                            <InfoBar IsClosable="False" IsOpen="True" Severity="Informational" Title="待确认加入 / 待确认移除" Message="{x:Bind ViewModel.PendingSummaryText, Mode=OneWay}" />
                            <Grid ColumnSpacing="10" RowSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.1*" />
                                    <ColumnDefinition Width="1*" />
                                    <ColumnDefinition Width="1*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBox Header="名称" Text="{x:Bind ViewModel.EditName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBox Grid.Column="1" Header="区域标签" Text="{x:Bind ViewModel.EditAreaLabel, Mode=TwoWay}" />
                                <ComboBox Grid.Column="2" Header="优先级" SelectedItem="{x:Bind ViewModel.EditPriority, Mode=TwoWay}">
                                    <x:String>重点</x:String>
                                    <x:String>常规</x:String>
                                    <x:String>低</x:String>
                                </ComboBox>
                                <ToggleSwitch Grid.Column="3" Header="状态" IsOn="{x:Bind ViewModel.EditEnabled, Mode=TwoWay}" OffContent="停用" OnContent="启用" />
                                <TextBox Grid.Row="1" Grid.ColumnSpan="3" Header="说明" Text="{x:Bind ViewModel.EditDescription, Mode=TwoWay}" />
                                <StackPanel Grid.Row="1" Grid.Column="3" VerticalAlignment="Bottom" Orientation="Horizontal" Spacing="8">
                                    <Button AutomationProperties.Name="保存分组" Command="{x:Bind ViewModel.SaveGroupCommand}" Style="{StaticResource PrimaryToolbarButtonStyle}" Content="保存" />
                                    <Button AutomationProperties.Name="删除分组" Click="DeleteGroup_Click" Style="{StaticResource ToolbarButtonStyle}" Content="删除" />
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource WorkbenchCardStyle}">
                        <StackPanel Spacing="10">
                            <StackPanel Spacing="2">
                                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="持续规则" />
                                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="持续覆盖楼层，也支持设备名精确匹配、设备名关键字匹配。成员须经用户确认。" TextWrapping="WrapWholeWords" />
                            </StackPanel>
                            <Grid ColumnSpacing="8" RowSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.2*" />
                                    <ColumnDefinition Width="0.8*" />
                                    <ColumnDefinition Width="0.8*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <ComboBox Header="规则类型" DisplayMemberPath="Label" ItemsSource="{x:Bind ViewModel.RuleTypes}" SelectedItem="{x:Bind ViewModel.SelectedRuleType, Mode=TwoWay}" />
                                <ComboBox
                                    Grid.Column="1"
                                    Header="楼栋（可选）"
                                    DisplayMemberPath="Label"
                                    ItemsSource="{x:Bind ViewModel.RuleBuildingOptions}"
                                    SelectedValue="{x:Bind ViewModel.RuleBuilding, Mode=TwoWay}"
                                    SelectedValuePath="Value" />
                                <TextBox Grid.Column="2" Header="楼层" PlaceholderText="如 3F" Text="{x:Bind ViewModel.RuleFloorLabel, Mode=TwoWay}" />
                                <TextBox Grid.Row="1" Grid.ColumnSpan="2" Header="设备名 / 关键字" PlaceholderText="精确匹配填写完整设备名；关键字匹配填写片段" Text="{x:Bind ViewModel.RuleKeyword, Mode=TwoWay}" />
                                <TextBox Grid.Row="1" Grid.Column="2" Header="备注" Text="{x:Bind ViewModel.RuleNote, Mode=TwoWay}" />
                                <ToggleSwitch Grid.Row="2" Header="规则状态" IsOn="{x:Bind ViewModel.EditRuleEnabled, Mode=TwoWay}" OffContent="停用" OnContent="启用" />
                                <StackPanel
                                    x:Name="RuleEditorActions"
                                    Grid.Row="2"
                                    Grid.Column="1"
                                    Grid.ColumnSpan="2"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Bottom"
                                    Orientation="Horizontal"
                                    Spacing="8">
                                    <Button AutomationProperties.Name="新建持续规则" Command="{x:Bind ViewModel.NewRuleCommand}" Style="{StaticResource ToolbarButtonStyle}" Content="新规则" />
                                    <Button AutomationProperties.Name="保存持续规则" Command="{x:Bind ViewModel.SaveRuleCommand}" Style="{StaticResource PrimaryToolbarButtonStyle}" Content="保存规则" />
                                </StackPanel>
                            </Grid>
                            <ListView MaxHeight="190" ItemsSource="{x:Bind ViewModel.Rules, Mode=OneWay}" SelectedItem="{x:Bind ViewModel.SelectedRule, Mode=TwoWay}" SelectionMode="Single">
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="groups:AreaGroupRuleRecord">
                                        <Grid Padding="0,6" ColumnSpacing="10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="120" />
                                                <ColumnDefinition Width="160" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock FontWeight="SemiBold" Text="{x:Bind RuleTypeLabel}" />
                                            <TextBlock Grid.Column="1" Text="{x:Bind ScopeLabel}" />
                                            <TextBlock Grid.Column="2" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind Note}" TextTrimming="CharacterEllipsis" />
                                            <Button Grid.Column="3" AutomationProperties.Name="删除持续规则" Click="DeleteRule_Click" Style="{StaticResource ToolbarButtonStyle}" Content="删除规则" />
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource WorkbenchCardStyle}">
                        <StackPanel Spacing="10">
                            <StackPanel Spacing="2">
                                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="现有设备目录" />
                                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="最少选择到楼层即可建立持续规则；也可继续筛到设备名并直接加入正式成员。" TextWrapping="WrapWholeWords" />
                            </StackPanel>
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="0.8*" />
                                    <ColumnDefinition Width="0.8*" />
                                    <ColumnDefinition Width="1.4*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <ComboBox Header="楼栋" ItemsSource="{x:Bind ViewModel.BuildingOptions}" SelectedItem="{x:Bind ViewModel.DeviceBuilding, Mode=TwoWay}" />
                                <TextBox Grid.Column="1" Header="楼层" PlaceholderText="如 3F" Text="{x:Bind ViewModel.DeviceFloor, Mode=TwoWay}" />
                                <TextBox Grid.Column="2" Header="搜索设备名 / UID" PlaceholderText="输入设备名关键字过滤当前目录" Text="{x:Bind ViewModel.DeviceDirectorySearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <StackPanel
                                    x:Name="DeviceDirectoryActions"
                                    Grid.Row="1"
                                    Grid.ColumnSpan="3"
                                    Margin="0,8,0,0"
                                    HorizontalAlignment="Right"
                                    Orientation="Horizontal"
                                    Spacing="8">
                                    <Button Command="{x:Bind ViewModel.LoadDeviceDirectoryCommand}" Style="{StaticResource ToolbarButtonStyle}" Content="查看现有设备" />
                                    <Button Command="{x:Bind ViewModel.AddFloorRuleCommand}" Style="{StaticResource PrimaryToolbarButtonStyle}" Content="选择楼层作为持续规则" />
                                </StackPanel>
                            </Grid>
                            <ListView
                                MaxHeight="230"
                                ItemsSource="{x:Bind ViewModel.DeviceDirectory, Mode=OneWay}"
                                SelectedItem="{x:Bind ViewModel.SelectedDevice, Mode=TwoWay}"
                                SelectionMode="Single">
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="vm:AreaGroupTargetOptionRow">
                                        <Grid Padding="0,6" ColumnSpacing="10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="100" />
                                                <ColumnDefinition Width="100" />
                                                <ColumnDefinition Width="150" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{x:Bind Building}" />
                                            <TextBlock Grid.Column="1" Text="{x:Bind FloorLabel}" />
                                            <TextBlock Grid.Column="2" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind SubAreaText}" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Grid.Column="3" FontWeight="SemiBold" Text="{x:Bind CardName}" TextTrimming="CharacterEllipsis" />
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox Header="备注" PlaceholderText="手动加入原因（可选）" Text="{x:Bind ViewModel.ManualMemberNote, Mode=TwoWay}" />
                                <Button Grid.Column="1" VerticalAlignment="Bottom" Command="{x:Bind ViewModel.AddManualMemberCommand}" Style="{StaticResource PrimaryToolbarButtonStyle}" Content="将设备直接加入分组" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource WorkbenchCardStyle}">
                        <StackPanel Spacing="10">
                            <StackPanel Spacing="2">
                                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="正式成员" />
                                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="手动成员可直接移除；规则成员移除后会进入长期屏蔽名单，避免下次再次匹配。" TextWrapping="WrapWholeWords" />
                            </StackPanel>
                            <ListView MaxHeight="260" ItemsSource="{x:Bind ViewModel.Members, Mode=OneWay}" SelectedItem="{x:Bind ViewModel.SelectedMember, Mode=TwoWay}" SelectionMode="Single">
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="groups:AreaGroupMemberRecord">
                                        <Grid Padding="0,6" ColumnSpacing="10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="90" />
                                                <ColumnDefinition Width="100" />
                                                <ColumnDefinition Width="110" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="1.2*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock FontWeight="SemiBold" Text="{x:Bind MemberOriginLabel}" />
                                            <TextBlock Grid.Column="1" Text="{x:Bind Building}" />
                                            <TextBlock Grid.Column="2" Text="{x:Bind FloorLabel}" />
                                            <TextBlock Grid.Column="3" Text="{x:Bind CardName}" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Grid.Column="4" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind Note}" TextTrimming="CharacterEllipsis" />
                                            <Button Grid.Column="5" AutomationProperties.Name="移除或屏蔽正式成员" Click="DeleteManualMember_Click" Style="{StaticResource ToolbarButtonStyle}" Content="移除 / 屏蔽" />
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox Header="成员备注" PlaceholderText="选择成员后修改备注" Text="{x:Bind ViewModel.MemberNote, Mode=TwoWay}" />
                                <Button Grid.Column="1" VerticalAlignment="Bottom" AutomationProperties.Name="保存成员备注" Command="{x:Bind ViewModel.UpdateMemberNoteCommand}" Style="{StaticResource PrimaryToolbarButtonStyle}" Content="保存备注" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource WorkbenchCardStyle}">
                        <StackPanel Spacing="10">
                            <StackPanel Spacing="2">
                                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="例外名单" />
                                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="长期屏蔽阻止规则再次加入；手动保留阻止规则自动移除。可修改备注或撤销例外。" TextWrapping="WrapWholeWords" />
                            </StackPanel>
                            <ListView
                                MaxHeight="230"
                                ItemsSource="{x:Bind ViewModel.Exceptions, Mode=OneWay}"
                                SelectedItem="{x:Bind ViewModel.SelectedException, Mode=TwoWay}"
                                SelectionMode="Single">
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="groups:AreaGroupExceptionRecord">
                                        <Grid Padding="0,6" ColumnSpacing="10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="110" />
                                                <ColumnDefinition Width="100" />
                                                <ColumnDefinition Width="110" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="1.2*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock FontWeight="SemiBold" Text="{x:Bind ExceptionTypeLabel}" />
                                            <TextBlock Grid.Column="1" Text="{x:Bind Building}" />
                                            <TextBlock Grid.Column="2" Text="{x:Bind FloorLabel}" />
                                            <TextBlock Grid.Column="3" Text="{x:Bind CardName}" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Grid.Column="4" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind Note}" TextTrimming="CharacterEllipsis" />
                                            <Button Grid.Column="5" AutomationProperties.Name="撤销分组例外" Click="DeleteException_Click" Style="{StaticResource ToolbarButtonStyle}" Content="撤销例外" />
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox Header="备注" PlaceholderText="选择一条例外后修改备注" Text="{x:Bind ViewModel.ExceptionNote, Mode=TwoWay}" />
                                <Button Grid.Column="1" VerticalAlignment="Bottom" Command="{x:Bind ViewModel.UpdateExceptionNoteCommand}" Style="{StaticResource PrimaryToolbarButtonStyle}" Content="保存备注" />
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>
