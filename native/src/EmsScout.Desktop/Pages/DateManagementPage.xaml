<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="EmsScout.Desktop.Pages.DateManagementPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:EmsScout.Desktop.ViewModels"
    Loaded="Page_Loaded"
    mc:Ignorable="d">
    <Grid Padding="{StaticResource PagePadding}" RowSpacing="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Spacing="3">
                <TextBlock Style="{StaticResource WorkbenchPageTitleStyle}" Text="规则与计划 · 日期" />
                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="按区域组和计划组批量维护日期与启用时段" />
                <TextBlock Foreground="{ThemeResource TextFillColorTertiaryBrush}" Text="{x:Bind ViewModel.StatusText, Mode=OneWay}" TextWrapping="WrapWholeWords" />
            </StackPanel>
            <Button Grid.Column="1" Click="Refresh_Click" Style="{StaticResource ToolbarButtonStyle}">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon FontSize="14" Glyph="&#xE72C;" />
                    <TextBlock Text="刷新" />
                </StackPanel>
            </Button>
        </Grid>

        <InfoBar
            Grid.Row="1"
            IsClosable="False"
            IsOpen="True"
            Severity="Informational"
            Title="日期计划只用于核查"
            Message="这里记录设备应在何时启用或不启用，不会向 EMS 下发开关命令。多选日期后可一次应用同一规则。" />

        <Grid Grid.Row="2" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Grid RowSpacing="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="1.05*" />
                    <RowDefinition Height="1*" />
                </Grid.RowDefinitions>
                <Border Style="{StaticResource WorkbenchCardStyle}" Padding="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <StackPanel Padding="14,12,14,8" Spacing="2">
                            <TextBlock Style="{StaticResource SectionTitleStyle}" Text="1. 选择区域组" />
                            <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="公区、非公区和自定义区域组均可设置日期计划。" TextWrapping="WrapWholeWords" />
                        </StackPanel>
                        <ListView
                            Grid.Row="1"
                            ItemsSource="{x:Bind ViewModel.AreaGroups, Mode=OneWay}"
                            SelectedItem="{x:Bind ViewModel.SelectedAreaGroup, Mode=TwoWay}">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="vm:GroupSummaryRow">
                                    <Grid Padding="8,6" ColumnSpacing="8">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                        <StackPanel Spacing="2">
                                            <TextBlock FontWeight="SemiBold" Text="{x:Bind Name}" />
                                            <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind StateLabel}" />
                                        </StackPanel>
                                        <TextBlock Grid.Column="1" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind ItemCountText}" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Border>

                <Border Grid.Row="1" Style="{StaticResource WorkbenchCardStyle}" Padding="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid Padding="14,12,14,8" ColumnSpacing="8">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <StackPanel Spacing="2">
                                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="2. 选择计划组" />
                                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="同一区域组可建立多套日期计划。" TextWrapping="WrapWholeWords" />
                            </StackPanel>
                            <Button Grid.Column="1" Command="{x:Bind ViewModel.NewScheduleGroupCommand}" IsEnabled="{x:Bind ViewModel.CanMaintain, Mode=OneWay}" Style="{StaticResource PrimaryToolbarButtonStyle}" Content="新建" />
                        </Grid>
                        <ListView
                            Grid.Row="1"
                            ItemsSource="{x:Bind ViewModel.ScheduleGroups, Mode=OneWay}"
                            SelectedItem="{x:Bind ViewModel.SelectedScheduleGroup, Mode=TwoWay}">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="vm:ScheduleGroupRow">
                                    <StackPanel Padding="8,6" Spacing="2">
                                        <TextBlock FontWeight="SemiBold" Text="{x:Bind Name}" />
                                        <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind RuleSummary}" />
                                        <TextBlock Foreground="{ThemeResource TextFillColorTertiaryBrush}" Text="{x:Bind MemberSummary}" />
                                    </StackPanel>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Border>
            </Grid>

            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="10">
                    <Border Style="{StaticResource WorkbenchCardStyle}">
                        <StackPanel Spacing="10">
                            <StackPanel Spacing="2">
                                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="计划组设置" />
                                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="计划组用于区分同一区域内不同对象或时段；保存后才能设置日期。" TextWrapping="WrapWholeWords" />
                            </StackPanel>
                            <Grid ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.2*" />
                                    <ColumnDefinition Width="1.6*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox Header="计划组名称" PlaceholderText="例如：公区工作日" Text="{x:Bind ViewModel.ScheduleGroupName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBox Grid.Column="1" Header="用途说明" PlaceholderText="说明适用范围或排查目的" Text="{x:Bind ViewModel.ScheduleGroupDescription, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <ToggleSwitch Grid.Column="2" Header="状态" IsOn="{x:Bind ViewModel.ScheduleGroupEnabled, Mode=TwoWay}" OnContent="启用" OffContent="停用" />
                                <StackPanel Grid.Column="3" VerticalAlignment="Bottom" Orientation="Horizontal" Spacing="6">
                                    <Button Command="{x:Bind ViewModel.SaveScheduleGroupCommand}" IsEnabled="{x:Bind ViewModel.CanSaveScheduleGroup, Mode=OneWay}" Style="{StaticResource PrimaryToolbarButtonStyle}" Content="保存计划组" />
                                    <Button Click="DeleteScheduleGroup_Click" IsEnabled="{x:Bind ViewModel.CanDeleteScheduleGroup, Mode=OneWay}" Content="删除" />
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource WorkbenchCardStyle}">
                        <StackPanel Spacing="10">
                            <StackPanel Spacing="2">
                                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="3. 在日历中选择日期" />
                                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="单击可选中或取消日期；支持跨月多选。蓝点表示按时段启用，灰点表示全天不启用。" TextWrapping="WrapWholeWords" />
                            </StackPanel>
                            <Grid ColumnSpacing="18">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.05*" />
                                    <ColumnDefinition Width="1*" />
                                </Grid.ColumnDefinitions>
                                <CalendarView
                                    x:Name="PlanCalendar"
                                    HorizontalAlignment="Stretch"
                                    CalendarViewDayItemChanging="PlanCalendar_DayItemChanging"
                                    FirstDayOfWeek="Monday"
                                    IsGroupLabelVisible="True"
                                    Language="zh-CN"
                                    NumberOfWeeksInView="6"
                                    SelectedDatesChanged="PlanCalendar_SelectedDatesChanged"
                                    SelectionMode="Multiple" />

                                <StackPanel Grid.Column="1" Spacing="10">
                                    <TextBlock FontWeight="SemiBold" Text="{x:Bind ViewModel.SelectionSummary, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                                    <ComboBox Header="选中日期的计划" SelectedValue="{x:Bind ViewModel.RuleStatus, Mode=TwoWay}" SelectedValuePath="Tag">
                                        <ComboBoxItem Content="按时间段启用" Tag="enabled" />
                                        <ComboBoxItem Content="全天不启用" Tag="not_open" />
                                    </ComboBox>
                                    <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind ViewModel.RuleTypeHelp, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                                    <StackPanel Spacing="8" Visibility="{x:Bind ViewModel.IntervalEditorVisibility, Mode=OneWay}">
                                        <Grid ColumnSpacing="8">
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                            <TextBlock VerticalAlignment="Center" FontWeight="SemiBold" Text="启用时间段" />
                                            <Button Grid.Column="1" Click="AddInterval_Click" Content="添加时间段" />
                                        </Grid>
                                        <ListView MaxHeight="190" ItemsSource="{x:Bind ViewModel.Intervals, Mode=OneWay}">
                                            <ListView.ItemTemplate>
                                                <DataTemplate x:DataType="vm:ScheduleIntervalEditorRow">
                                                    <Grid Padding="0,4" ColumnSpacing="8">
                                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                                        <TimePicker ClockIdentifier="24HourClock" Header="开始" MinuteIncrement="5" Time="{x:Bind StartTime, Mode=TwoWay}" />
                                                        <TextBlock Grid.Column="1" VerticalAlignment="Center" Margin="0,20,0,0" Text="至" />
                                                        <TimePicker Grid.Column="2" ClockIdentifier="24HourClock" Header="结束" MinuteIncrement="5" Time="{x:Bind EndTime, Mode=TwoWay}" />
                                                        <Button Grid.Column="3" VerticalAlignment="Bottom" Click="RemoveInterval_Click" Content="移除" />
                                                    </Grid>
                                                </DataTemplate>
                                            </ListView.ItemTemplate>
                                        </ListView>
                                    </StackPanel>
                                    <TextBox Header="备注" PlaceholderText="可填写节假日、施工或临时排查原因" Text="{x:Bind ViewModel.RuleNote, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <Button Command="{x:Bind ViewModel.ApplyDatesCommand}" IsEnabled="{x:Bind ViewModel.CanApplyDates, Mode=OneWay}" Style="{StaticResource PrimaryToolbarButtonStyle}" Content="应用到选中日期" />
                                        <Button Click="DeleteSelectedDates_Click" IsEnabled="{x:Bind ViewModel.CanRemoveSelectedDates, Mode=OneWay}" Content="删除选中日期规则" />
                                        <Button Click="ClearSelection_Click" Content="清除选择" />
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource WorkbenchCardStyle}">
                        <StackPanel Spacing="8">
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="已配置日期" />
                                <TextBlock Grid.Column="1" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind ViewModel.ConfiguredSummary, Mode=OneWay}" />
                            </Grid>
                            <ListView MaxHeight="210" ItemsSource="{x:Bind ViewModel.Rules, Mode=OneWay}">
                                <ListView.Header>
                                    <Grid ColumnSpacing="12"><Grid.ColumnDefinitions><ColumnDefinition Width="120" /><ColumnDefinition Width="120" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><TextBlock FontWeight="SemiBold" Text="日期" /><TextBlock Grid.Column="1" FontWeight="SemiBold" Text="计划" /><TextBlock Grid.Column="2" FontWeight="SemiBold" Text="时间段" /><TextBlock Grid.Column="3" FontWeight="SemiBold" Text="操作" /></Grid>
                                </ListView.Header>
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="vm:ScheduleRuleRow">
                                        <Grid Padding="0,5" ColumnSpacing="12"><Grid.ColumnDefinitions><ColumnDefinition Width="120" /><ColumnDefinition Width="120" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><TextBlock Text="{x:Bind Date}" /><TextBlock Grid.Column="1" Text="{x:Bind StatusLabel}" /><TextBlock Grid.Column="2" Text="{x:Bind IntervalsText}" TextTrimming="CharacterEllipsis" /><Button Grid.Column="3" Click="EditRule_Click" Content="在日历中编辑" /></Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource WorkbenchCardStyle}">
                        <StackPanel Spacing="10">
                            <TextBlock Style="{StaticResource SectionTitleStyle}" Text="4. 设置适用对象" />
                            <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind ViewModel.AreaMemberSummary, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                            <Grid ColumnSpacing="14">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="1*" /><ColumnDefinition Width="1.2*" /></Grid.ColumnDefinitions>
                                <StackPanel Spacing="6">
                                    <TextBlock FontWeight="SemiBold" Text="区域组成员" />
                                    <ListView MaxHeight="230" ItemsSource="{x:Bind ViewModel.AreaMembers, Mode=OneWay}">
                                        <ListView.ItemTemplate>
                                            <DataTemplate x:DataType="vm:AreaGroupItemRow">
                                                <Grid Padding="0,4" ColumnSpacing="8"><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><StackPanel><TextBlock FontWeight="SemiBold" Text="{x:Bind TargetTypeLabel}" /><TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind TargetLabel}" TextWrapping="WrapWholeWords" /></StackPanel><Button Grid.Column="1" VerticalAlignment="Center" Click="AddMember_Click" Content="加入当前计划" /></Grid>
                                            </DataTemplate>
                                        </ListView.ItemTemplate>
                                    </ListView>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="6">
                                    <TextBlock FontWeight="SemiBold" Text="当前计划组对象" />
                                    <ListView MaxHeight="230" ItemsSource="{x:Bind ViewModel.ScheduleMembers, Mode=OneWay}">
                                        <ListView.ItemTemplate>
                                            <DataTemplate x:DataType="vm:ScheduleMemberRow">
                                                <Grid Padding="0,4" ColumnSpacing="8"><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="110" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><StackPanel><TextBlock FontWeight="SemiBold" Text="{x:Bind TargetTypeLabel}" /><TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind TargetLabel}" TextWrapping="WrapWholeWords" /></StackPanel><TextBlock Grid.Column="1" VerticalAlignment="Center" Text="{x:Bind ExpectedStatusLabel}" /><StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4"><Button Click="MarkNormal_Click" Content="按日期" /><Button Click="MarkNotOpen_Click" Content="未开放" /><Button Click="RemoveMember_Click" Content="移除" /></StackPanel></Grid>
                                            </DataTemplate>
                                        </ListView.ItemTemplate>
                                    </ListView>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>
