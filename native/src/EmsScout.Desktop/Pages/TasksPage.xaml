<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Name="TaskRoot"
    x:Class="EmsScout.Desktop.Pages.TasksPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Loaded="Page_Loaded"
    SizeChanged="Page_SizeChanged"
    mc:Ignorable="d">
    <Grid Padding="{StaticResource PagePadding}" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Spacing="3">
                <TextBlock Style="{StaticResource WorkbenchPageTitleStyle}" Text="采集" />
                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="采集 EMS 空调数据并更新数据管理" />
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                <Button
                    Click="StartTask_Click"
                    IsEnabled="{x:Bind ViewModel.CanStartTask, Mode=OneWay}"
                    Style="{StaticResource PrimaryToolbarButtonStyle}"
                    Visibility="{x:Bind ViewModel.StartPrimaryButtonVisibility, Mode=OneWay}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon FontSize="14" Glyph="&#xE768;" />
                        <TextBlock Text="{x:Bind ViewModel.StartButtonText, Mode=OneWay}" />
                    </StackPanel>
                </Button>
                <Button
                    Click="StartTask_Click"
                    IsEnabled="{x:Bind ViewModel.CanStartTask, Mode=OneWay}"
                    Style="{StaticResource ToolbarButtonStyle}"
                    Visibility="{x:Bind ViewModel.StartSecondaryButtonVisibility, Mode=OneWay}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon FontSize="14" Glyph="&#xE768;" />
                        <TextBlock Text="{x:Bind ViewModel.StartButtonText, Mode=OneWay}" />
                    </StackPanel>
                </Button>
                <Button
                    Click="StopTask_Click"
                    IsEnabled="{x:Bind ViewModel.IsRunning, Mode=OneWay}"
                    Style="{StaticResource ToolbarButtonStyle}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon FontSize="14" Glyph="&#xE71A;" />
                        <TextBlock Text="停止" />
                    </StackPanel>
                </Button>
                <Button Command="{x:Bind ViewModel.OpenDataCommand}" Style="{StaticResource ToolbarButtonStyle}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon FontSize="14" Glyph="&#xE8A5;" />
                        <TextBlock Text="数据管理" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <Border
            Grid.Row="1"
            Padding="14,10"
            Background="{ThemeResource SubtleFillColorSecondaryBrush}"
            CornerRadius="6">
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <FontIcon
                    VerticalAlignment="Center"
                    FontSize="18"
                    Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                    Glyph="{x:Bind ViewModel.ReadinessGlyph, Mode=OneWay}" />
                <StackPanel Grid.Column="1" Spacing="2">
                    <TextBlock FontWeight="SemiBold" Text="{x:Bind ViewModel.ReadinessTitle, Mode=OneWay}" />
                    <TextBlock
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="{x:Bind ViewModel.ReadinessDetail, Mode=OneWay}"
                        TextWrapping="WrapWholeWords" />
                </StackPanel>
                <Button
                    Grid.Column="2"
                    Command="{x:Bind ViewModel.ToggleCollectionBrowserCommand}"
                    Style="{StaticResource PrimaryToolbarButtonStyle}"
                    ToolTipService.ToolTip="{x:Bind ViewModel.CollectionBrowserActionToolTip, Mode=OneWay}"
                    Visibility="{x:Bind ViewModel.CollectionBrowserPrimaryButtonVisibility, Mode=OneWay}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon FontSize="14" Glyph="{x:Bind ViewModel.CollectionBrowserActionGlyph, Mode=OneWay}" />
                        <TextBlock Text="{x:Bind ViewModel.CollectionBrowserActionText, Mode=OneWay}" />
                    </StackPanel>
                </Button>
                <Button
                    Grid.Column="2"
                    Command="{x:Bind ViewModel.ToggleCollectionBrowserCommand}"
                    Style="{StaticResource ToolbarButtonStyle}"
                    ToolTipService.ToolTip="{x:Bind ViewModel.CollectionBrowserActionToolTip, Mode=OneWay}"
                    Visibility="{x:Bind ViewModel.CollectionBrowserSecondaryButtonVisibility, Mode=OneWay}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon FontSize="14" Glyph="{x:Bind ViewModel.CollectionBrowserActionGlyph, Mode=OneWay}" />
                        <TextBlock Text="{x:Bind ViewModel.CollectionBrowserActionText, Mode=OneWay}" />
                    </StackPanel>
                </Button>
                <Button
                    Grid.Column="3"
                    Command="{x:Bind ViewModel.CheckEnvironmentCommand}"
                    Style="{StaticResource ToolbarButtonStyle}"
                    Content="重新检查"
                    ToolTipService.ToolTip="重新检查采集环境" />
            </Grid>
        </Border>

        <Grid x:Name="WorkflowGrid" Grid.Row="2" ColumnSpacing="14" RowSpacing="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="SetupColumn" MinWidth="0" Width="0.9*" />
                <ColumnDefinition x:Name="ExecutionColumn" MinWidth="0" Width="1.35*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition x:Name="SetupRow" Height="*" />
                <RowDefinition x:Name="ExecutionRow" Height="0" />
            </Grid.RowDefinitions>

            <ScrollViewer
                x:Name="SetupPanel"
                HorizontalScrollBarVisibility="Disabled"
                HorizontalScrollMode="Disabled"
                VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="12">
                    <Border Style="{StaticResource WorkbenchCardStyle}">
                        <StackPanel Spacing="10">
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="2">
                                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="采集范围" />
                                    <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind ViewModel.SelectedBuildingsText, Mode=OneWay}" />
                                </StackPanel>
                                <Button Grid.Column="1" Command="{x:Bind ViewModel.SelectAllBuildingsCommand}" Style="{StaticResource ToolbarButtonStyle}" Content="全选" />
                                <Button Grid.Column="2" Command="{x:Bind ViewModel.ClearBuildingSelectionCommand}" Style="{StaticResource ToolbarButtonStyle}" Content="清空" />
                            </Grid>
                            <ItemsControl ItemsSource="{x:Bind ViewModel.Buildings, Mode=OneWay}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <ItemsWrapGrid Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <CheckBox
                                            MinWidth="118"
                                            Margin="0,0,8,5"
                                            Content="{Binding Label}"
                                            IsEnabled="{Binding ViewModel.CanEditBuildingSelectionOptions, ElementName=TaskRoot}"
                                            IsChecked="{Binding IsSelected, Mode=TwoWay}" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="{x:Bind ViewModel.CurrentDataImpactText, Mode=OneWay}"
                                Visibility="{x:Bind ViewModel.CurrentDataImpactVisibility, Mode=OneWay}"
                                TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Border x:Name="PreflightStatusPanel" Style="{StaticResource WorkbenchCardStyle}">
                        <StackPanel Spacing="10">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="2">
                                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="运行前检查" />
                                    <TextBlock
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Text="以下项目会随环境检查自动更新" />
                                </StackPanel>
                                <TextBlock
                                    Grid.Column="1"
                                    VerticalAlignment="Bottom"
                                    FontWeight="SemiBold"
                                    Text="{x:Bind ViewModel.PreflightDetailsHeader, Mode=OneWay}" />
                            </Grid>
                            <ProgressBar
                                Height="4"
                                Maximum="100"
                                Value="{x:Bind ViewModel.PreflightProgressValue, Mode=OneWay}" />
                            <ItemsControl ItemsSource="{x:Bind ViewModel.PreflightChecks, Mode=OneWay}">
                                <ItemsControl.ItemContainerTransitions>
                                    <TransitionCollection>
                                        <EntranceThemeTransition FromHorizontalOffset="24" IsStaggeringEnabled="True" />
                                        <RepositionThemeTransition />
                                    </TransitionCollection>
                                </ItemsControl.ItemContainerTransitions>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid MinHeight="38" Padding="0,4" ColumnSpacing="10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="28" />
                                                <ColumnDefinition Width="94" />
                                                <ColumnDefinition Width="54" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Border
                                                x:Name="StatusBadge"
                                                Width="26"
                                                Height="26"
                                                VerticalAlignment="Center"
                                                Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                                CornerRadius="13">
                                                <FontIcon
                                                    x:Name="StatusIcon"
                                                    FontSize="13"
                                                    Foreground="{Binding IconForeground}"
                                                    Glyph="{Binding Glyph}" />
                                            </Border>
                                            <TextBlock
                                                Grid.Column="1"
                                                VerticalAlignment="Center"
                                                FontWeight="SemiBold"
                                                Text="{Binding Title}" />
                                            <TextBlock
                                                x:Name="StatusText"
                                                Grid.Column="2"
                                                VerticalAlignment="Center"
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                Text="{Binding State}" />
                                            <TextBlock
                                                Grid.Column="3"
                                                VerticalAlignment="Center"
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                Text="{Binding Detail}"
                                                TextTrimming="CharacterEllipsis" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Expander HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
                        <Expander.Header>
                            <StackPanel Spacing="2">
                                <TextBlock FontWeight="SemiBold" Text="高级设置" />
                                <TextBlock Foreground="{ThemeResource TextFillColorTertiaryBrush}" Text="采集方式、补采和诊断选项" />
                            </StackPanel>
                        </Expander.Header>
                        <StackPanel Spacing="10">
                            <ComboBox
                                Header="采集方式"
                                DisplayMemberPath="Label"
                                IsEnabled="{x:Bind ViewModel.CanEditTaskOptions, Mode=OneWay}"
                                ItemsSource="{x:Bind ViewModel.TaskModes, Mode=OneWay}"
                                SelectedItem="{x:Bind ViewModel.SelectedTaskMode, Mode=TwoWay}" />
                            <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind ViewModel.TaskModeDescription, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                            <StackPanel
                                x:Name="RecaptureLocationPanel"
                                x:Load="{x:Bind ViewModel.IsRecaptureMode, Mode=OneWay}"
                                Spacing="6">
                                <TextBlock FontWeight="SemiBold" Text="补采定位" />
                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <ComboBox
                                        x:Name="RecaptureBuildingSelector"
                                        Header="楼栋"
                                        DisplayMemberPath="Label"
                                        IsEnabled="{x:Bind ViewModel.CanEditTaskOptions, Mode=OneWay}"
                                        ItemsSource="{x:Bind ViewModel.RecaptureBuildingOptions, Mode=OneWay}"
                                        SelectedItem="{x:Bind ViewModel.SelectedRecaptureBuilding, Mode=TwoWay}" />
                                    <ComboBox
                                        x:Name="RecaptureSeatSelector"
                                        Grid.Column="1"
                                        Header="座号"
                                        DisplayMemberPath="Label"
                                        IsEnabled="{x:Bind ViewModel.CanSelectRecaptureSeat, Mode=OneWay}"
                                        ItemsSource="{x:Bind ViewModel.RecaptureSeatOptions, Mode=OneWay}"
                                        SelectedItem="{x:Bind ViewModel.SelectedRecaptureSeat, Mode=TwoWay}" />
                                    <ComboBox
                                        x:Name="RecaptureFloorSelector"
                                        Grid.Column="2"
                                        Header="楼层"
                                        DisplayMemberPath="Label"
                                        IsEnabled="{x:Bind ViewModel.CanSelectRecaptureFloor, Mode=OneWay}"
                                        ItemsSource="{x:Bind ViewModel.RecaptureFloorOptions, Mode=OneWay}"
                                        SelectedItem="{x:Bind ViewModel.SelectedRecaptureFloor, Mode=TwoWay}" />
                                </Grid>
                                <TextBlock
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Text="{x:Bind ViewModel.RecaptureLocationStatus, Mode=OneWay}"
                                    TextWrapping="WrapWholeWords" />
                            </StackPanel>
                            <ToggleSwitch
                                Header="保存诊断日志"
                                IsEnabled="{x:Bind ViewModel.CanEditTaskOptions, Mode=OneWay}"
                                IsOn="{x:Bind ViewModel.EnableLogFile, Mode=TwoWay}" />
                        </StackPanel>
                    </Expander>
                </StackPanel>
            </ScrollViewer>

            <Grid x:Name="ExecutionPanel" Grid.Column="1" RowSpacing="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Border
                    Style="{StaticResource WorkbenchCardStyle}"
                    Visibility="{x:Bind ViewModel.TaskProgressVisibility, Mode=OneWay}">
                    <StackPanel Spacing="10">
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="2">
                                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="任务进度" />
                                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind ViewModel.StatusText, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                            </StackPanel>
                            <TextBlock Grid.Column="1" VerticalAlignment="Bottom" FontWeight="SemiBold" Text="{x:Bind ViewModel.ProgressText, Mode=OneWay}" />
                        </Grid>
                        <ProgressBar IsIndeterminate="{x:Bind ViewModel.IsProgressIndeterminate, Mode=OneWay}" Value="{x:Bind ViewModel.ProgressValue, Mode=OneWay}" />
                        <Grid ColumnSpacing="12" RowSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="2">
                                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="当前活动" />
                                <TextBlock Text="{x:Bind ViewModel.CurrentActivityText, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Spacing="2">
                                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="当前楼栋" />
                                <TextBlock Text="{x:Bind ViewModel.CurrentBuildingText, Mode=OneWay}" />
                            </StackPanel>
                            <StackPanel Grid.Column="2" Spacing="2">
                                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="采集计数" />
                                <TextBlock Text="{x:Bind ViewModel.CollectedCountText, Mode=OneWay}" />
                            </StackPanel>
                            <StackPanel Grid.Column="3" Spacing="2">
                                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="数据状态" />
                                <TextBlock Text="{x:Bind ViewModel.DataUpdateText, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                            <StackPanel Grid.Column="4" Spacing="2">
                                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="运行时长" />
                                <TextBlock Text="{x:Bind ViewModel.RunDurationText, Mode=OneWay}" />
                            </StackPanel>
                            <StackPanel Grid.Column="5" Spacing="2">
                                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="最近心跳" />
                                <TextBlock Text="{x:Bind ViewModel.LastHeartbeatText, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </Grid>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Command="{x:Bind ViewModel.OpenDataCommand}" Style="{StaticResource ToolbarButtonStyle}" Content="打开数据管理" />
                            <Button Command="{x:Bind ViewModel.OpenAuditCommand}" Style="{StaticResource ToolbarButtonStyle}" Content="查看审计结果" />
                        </StackPanel>
                        <ItemsControl ItemsSource="{x:Bind ViewModel.Stages, Mode=OneWay}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Padding="0,7" ColumnSpacing="10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="24" />
                                            <ColumnDefinition Width="150" />
                                            <ColumnDefinition Width="72" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <FontIcon FontSize="13" Glyph="&#xE915;" />
                                        <TextBlock Grid.Column="1" FontWeight="SemiBold" Text="{Binding Label}" />
                                        <TextBlock Grid.Column="2" Text="{Binding State}" />
                                        <TextBlock Grid.Column="3" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{Binding Detail}" TextWrapping="WrapWholeWords" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border
                    Grid.Row="{x:Bind ViewModel.LogsGridRow, Mode=OneWay}"
                    Grid.RowSpan="{x:Bind ViewModel.LogsGridRowSpan, Mode=OneWay}"
                    Style="{StaticResource WorkbenchCardStyle}">
                    <Grid RowSpacing="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="2">
                                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="运行记录" />
                                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="失败时保留最后 300 条记录用于排查" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                                <Button
                                    AutomationProperties.Name="清空运行记录"
                                    Command="{x:Bind ViewModel.ClearLogsCommand}"
                                    IsEnabled="{x:Bind ViewModel.CanClearLogs, Mode=OneWay}"
                                    Style="{StaticResource ToolbarButtonStyle}"
                                    ToolTipService.ToolTip="清空运行记录"
                                    Width="32"
                                    Height="32"
                                    Padding="0">
                                    <FontIcon FontSize="14" Glyph="&#xE74D;" />
                                </Button>
                                <Button
                                    AutomationProperties.Name="展开运行记录"
                                    Command="{x:Bind ViewModel.ToggleLogsExpandedCommand}"
                                    Style="{StaticResource ToolbarButtonStyle}"
                                    ToolTipService.ToolTip="展开运行记录"
                                    Visibility="{x:Bind ViewModel.LogsExpandButtonVisibility, Mode=OneWay}"
                                    Width="32"
                                    Height="32"
                                    Padding="0">
                                    <FontIcon FontSize="14" Glyph="&#xE740;" />
                                </Button>
                                <Button
                                    AutomationProperties.Name="还原任务进度布局"
                                    Command="{x:Bind ViewModel.ToggleLogsExpandedCommand}"
                                    Style="{StaticResource ToolbarButtonStyle}"
                                    ToolTipService.ToolTip="还原任务进度布局"
                                    Visibility="{x:Bind ViewModel.LogsRestoreButtonVisibility, Mode=OneWay}"
                                    Width="32"
                                    Height="32"
                                    Padding="0">
                                    <FontIcon FontSize="14" Glyph="&#xE73F;" />
                                </Button>
                            </StackPanel>
                        </Grid>
                        <ListView
                            x:Name="LogsList"
                            Grid.Row="1"
                            ItemsSource="{x:Bind ViewModel.Logs, Mode=OneWay}"
                            SelectionMode="None">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Padding="0,3" ColumnSpacing="10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="70" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Foreground="{ThemeResource TextFillColorTertiaryBrush}" Text="{Binding Time}" />
                                        <TextBlock Grid.Column="1" Text="{Binding Message}" TextWrapping="WrapWholeWords" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Page>
