<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Name="DataRoot"
    x:Class="EmsScout.Desktop.Pages.DataPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Loaded="Page_Loaded"
    mc:Ignorable="d">
    <Grid Padding="{StaticResource PagePadding}" RowSpacing="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Spacing="3">
                <TextBlock Style="{StaticResource WorkbenchPageTitleStyle}" Text="设备数据" />
                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind ViewModel.StatusText, Mode=OneWay}" />
                <TextBlock Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" Text="{x:Bind ViewModel.DataStateText, Mode=OneWay}" />
                <TextBlock Foreground="{ThemeResource TextFillColorTertiaryBrush}" Text="{x:Bind ViewModel.LastExportPath, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                <TextBlock Foreground="{ThemeResource TextFillColorTertiaryBrush}" Text="{x:Bind ViewModel.ExportHint, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                <TextBlock FontWeight="SemiBold" Text="{x:Bind ViewModel.ExportPreviewText, Mode=OneWay}" />
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Top">
                <ComboBox
                    Width="250"
                    Header="数据批次"
                    DisplayMemberPath="DisplayText"
                    ItemsSource="{x:Bind ViewModel.DataContext.Options, Mode=OneWay}"
                    SelectedItem="{x:Bind ViewModel.DataContext.Selected, Mode=TwoWay}"
                    SelectionChanged="DataContext_SelectionChanged" />
                <Button
                    Click="OpenExportLocation_Click"
                    Style="{StaticResource ToolbarButtonStyle}"
                    IsEnabled="{x:Bind ViewModel.CanOpenLastExport, Mode=OneWay}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon FontSize="14" Glyph="&#xE838;" />
                        <TextBlock Text="打开导出位置" />
                    </StackPanel>
                </Button>
                <Button
                    Click="Export_Click"
                    Style="{StaticResource PrimaryToolbarButtonStyle}"
                    IsEnabled="{x:Bind ViewModel.CanExport, Mode=OneWay}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon FontSize="14" Glyph="&#xE118;" />
                        <TextBlock Text="导出筛选 Excel" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <Border Grid.Row="1" Style="{StaticResource WorkbenchCardStyle}">
            <Grid RowSpacing="6">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Spacing="2">
                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="筛选条件" />
                        <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="筛选和 Excel 导出使用同一组条件。" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                        <Button Click="ApplyFilters_Click" Style="{StaticResource PrimaryToolbarButtonStyle}" IsEnabled="{x:Bind ViewModel.CanRunDataAction, Mode=OneWay}">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon FontSize="14" Glyph="&#xE71C;" />
                                <TextBlock Text="筛选" />
                            </StackPanel>
                        </Button>
                        <Button Click="ResetFilters_Click" Style="{StaticResource ToolbarButtonStyle}" IsEnabled="{x:Bind ViewModel.CanRunDataAction, Mode=OneWay}">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon FontSize="14" Glyph="&#xE777;" />
                                <TextBlock Text="重置" />
                            </StackPanel>
                        </Button>
                        <Button Click="Refresh_Click" Style="{StaticResource ToolbarButtonStyle}" IsEnabled="{x:Bind ViewModel.CanRunDataAction, Mode=OneWay}">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon FontSize="14" Glyph="&#xE72C;" />
                                <TextBlock Text="刷新" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="1" ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="快捷筛选" />
                    <ItemsControl Grid.Column="1" ItemsSource="{x:Bind ViewModel.QuickFilters, Mode=OneWay}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="6" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <ToggleButton
                                    Click="QuickFilter_Click"
                                    Content="{Binding DisplayText}"
                                    IsChecked="{Binding IsActive, Mode=OneWay}"
                                    Tag="{Binding Key}"
                                    MinHeight="32"
                                    Padding="12,5"
                                    AutomationProperties.Name="{Binding DisplayText}"
                                    ToolTipService.ToolTip="{Binding DisplayText}" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>

                <Expander Grid.Row="2" Header="更多筛选" IsExpanded="False">
                    <Grid ColumnSpacing="8" RowSpacing="6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1*" MinWidth="108" />
                            <ColumnDefinition Width="1*" MinWidth="108" />
                            <ColumnDefinition Width="1*" MinWidth="108" />
                            <ColumnDefinition Width="1*" MinWidth="108" />
                            <ColumnDefinition Width="1.25*" MinWidth="132" />
                            <ColumnDefinition Width="1.35*" MinWidth="145" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.ColumnSpan="6" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="位置定位" />
                        <ComboBox Grid.Row="1" Header="楼栋" DisplayMemberPath="DisplayLabel" ItemsSource="{x:Bind ViewModel.BuildingOptions, Mode=OneWay}" SelectedItem="{x:Bind ViewModel.SelectedBuilding, Mode=TwoWay}" SelectionChanged="BuildingFilter_SelectionChanged" />
                        <ComboBox Grid.Row="1" Grid.Column="1" Header="座号" DisplayMemberPath="DisplayLabel" ItemsSource="{x:Bind ViewModel.ZuoOptions, Mode=OneWay}" SelectedItem="{x:Bind ViewModel.SelectedZuo, Mode=TwoWay}" IsEnabled="{x:Bind ViewModel.CanFilterByZuo, Mode=OneWay}" ToolTipService.ToolTip="仅适用于5号、6号楼" />
                        <ComboBox Grid.Row="1" Grid.Column="2" Header="楼层" DisplayMemberPath="DisplayLabel" ItemsSource="{x:Bind ViewModel.FloorOptions, Mode=OneWay}" SelectedItem="{x:Bind ViewModel.SelectedFloor, Mode=TwoWay}" SelectionChanged="FloorFilter_SelectionChanged" />
                        <ComboBox Grid.Row="1" Grid.Column="3" Header="子区" DisplayMemberPath="DisplayLabel" ItemsSource="{x:Bind ViewModel.SubAreaOptions, Mode=OneWay}" SelectedItem="{x:Bind ViewModel.SelectedSubArea, Mode=TwoWay}" SelectionChanged="SubAreaFilter_SelectionChanged" />
                        <ComboBox Grid.Row="1" Grid.Column="4" Header="页面" DisplayMemberPath="DisplayLabel" ItemsSource="{x:Bind ViewModel.PageNameOptions, Mode=OneWay}" SelectedItem="{x:Bind ViewModel.SelectedPageName, Mode=TwoWay}" />
                        <TextBox Grid.Row="1" Grid.Column="5" Header="设备名" PlaceholderText="输入后按 Enter 查询" KeyDown="DeviceName_KeyDown" Text="{x:Bind ViewModel.DeviceNameText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Grid.Row="2" Grid.ColumnSpan="6" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="状态筛选" />
                        <ComboBox Grid.Row="3" Header="区域" DisplayMemberPath="DisplayLabel" ItemsSource="{x:Bind ViewModel.AreaOptions, Mode=OneWay}" SelectedItem="{x:Bind ViewModel.SelectedArea, Mode=TwoWay}" />
                        <ComboBox Grid.Row="3" Grid.Column="1" Header="开关机状态" DisplayMemberPath="DisplayLabel" ItemsSource="{x:Bind ViewModel.CommunicationOptions, Mode=OneWay}" SelectedItem="{x:Bind ViewModel.SelectedCommunication, Mode=TwoWay}" />
                        <ComboBox Grid.Row="3" Grid.Column="2" Header="模式" DisplayMemberPath="DisplayLabel" ItemsSource="{x:Bind ViewModel.ModeOptions, Mode=OneWay}" SelectedItem="{x:Bind ViewModel.SelectedMode, Mode=TwoWay}" />
                        <ComboBox Grid.Row="3" Grid.Column="3" Header="风速" DisplayMemberPath="DisplayLabel" ItemsSource="{x:Bind ViewModel.FanOptions, Mode=OneWay}" SelectedItem="{x:Bind ViewModel.SelectedFan, Mode=TwoWay}" />
                        <ComboBox Grid.Row="3" Grid.Column="4" Header="设置温度(℃)" DisplayMemberPath="DisplayLabel" ItemsSource="{x:Bind ViewModel.SetTemperatureOptions, Mode=OneWay}" SelectedItem="{x:Bind ViewModel.SelectedSetTemperature, Mode=TwoWay}" />
                        <ComboBox Grid.Row="3" Grid.Column="5" Header="集控锁定状态" DisplayMemberPath="DisplayLabel" ItemsSource="{x:Bind ViewModel.RealtimeLockOptions, Mode=OneWay}" SelectedItem="{x:Bind ViewModel.SelectedRealtimeLock, Mode=TwoWay}" />
                    </Grid>
                </Expander>

            </Grid>
        </Border>

        <Border
            Grid.Row="2"
            Padding="12,8"
            Background="{ThemeResource SystemFillColorCriticalBackgroundBrush}"
            CornerRadius="4"
            Visibility="{x:Bind ViewModel.LoadErrorVisibility, Mode=OneWay}">
            <Grid ColumnSpacing="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Spacing="2">
                    <TextBlock FontWeight="SemiBold" Text="设备数据读取失败" />
                    <TextBlock Text="{x:Bind ViewModel.LoadErrorText, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                    <TextBlock
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="当前显示上次成功结果"
                        Visibility="{x:Bind ViewModel.StaleResultsVisibility, Mode=OneWay}" />
                </StackPanel>
                <Button Grid.Column="1" Click="RetryLoad_Click" Style="{StaticResource ToolbarButtonStyle}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon FontSize="14" Glyph="&#xE72C;" />
                        <TextBlock Text="重试" />
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <Grid Grid.Row="3" ColumnSpacing="14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="360" />
            </Grid.ColumnDefinitions>

            <ProgressBar
                Grid.ColumnSpan="2"
                VerticalAlignment="Top"
                IsIndeterminate="{x:Bind ViewModel.IsLoading, Mode=OneWay}" />

            <Border Style="{StaticResource WorkbenchCardStyle}" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid Padding="14,8" ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center" Spacing="2">
                            <TextBlock
                                FontWeight="SemiBold"
                                Text="{x:Bind ViewModel.ResultSummary, Mode=OneWay}"
                                TextTrimming="CharacterEllipsis" />
                            <TextBlock
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="{x:Bind ViewModel.ActiveFilterSummary, Mode=OneWay}"
                                MaxLines="3"
                                TextWrapping="WrapWholeWords"
                                ToolTipService.ToolTip="{x:Bind ViewModel.ActiveFilterSummary, Mode=OneWay}" />
                        </StackPanel>
                        <Button
                            Grid.Column="1"
                            Click="PreviousPage_Click"
                            Style="{StaticResource ToolbarButtonStyle}"
                            AutomationProperties.Name="上一页"
                            ToolTipService.ToolTip="上一页"
                            IsEnabled="{x:Bind ViewModel.CanMovePrevious, Mode=OneWay}">
                            <FontIcon FontSize="14" Glyph="&#xE72B;" />
                        </Button>
                        <TextBlock
                            Grid.Column="2"
                            MinWidth="92"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="{x:Bind ViewModel.PageSummary, Mode=OneWay}" />
                        <Button
                            Grid.Column="3"
                            Click="NextPage_Click"
                            Style="{StaticResource ToolbarButtonStyle}"
                            AutomationProperties.Name="下一页"
                            ToolTipService.ToolTip="下一页"
                            IsEnabled="{x:Bind ViewModel.CanMoveNext, Mode=OneWay}">
                            <FontIcon FontSize="14" Glyph="&#xE72A;" />
                        </Button>
                    </Grid>
                    <ListView
                        Grid.Row="1"
                        ItemsSource="{x:Bind ViewModel.Devices, Mode=OneWay}"
                        SelectedItem="{x:Bind ViewModel.SelectedDevice, Mode=TwoWay}"
                        SelectionChanged="DeviceList_SelectionChanged"
                        ScrollViewer.HorizontalScrollBarVisibility="Auto"
                        Visibility="{x:Bind ViewModel.ResultListVisibility, Mode=OneWay}"
                        SelectionMode="Single">
                        <ListView.Header>
                            <Grid MinWidth="1620" Padding="{x:Bind ViewModel.TableHeaderPadding, Mode=OneWay}" ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="90" />
                                    <ColumnDefinition Width="86" />
                                    <ColumnDefinition Width="86" />
                                    <ColumnDefinition Width="210" />
                                    <ColumnDefinition Width="190" />
                                    <ColumnDefinition Width="92" />
                                    <ColumnDefinition Width="110" />
                                    <ColumnDefinition Width="92" />
                                    <ColumnDefinition Width="82" />
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="140" />
                                </Grid.ColumnDefinitions>
                                <TextBlock FontWeight="SemiBold" Text="楼栋" />
                                <TextBlock Grid.Column="1" FontWeight="SemiBold" Text="座号" />
                                <TextBlock Grid.Column="2" FontWeight="SemiBold" Text="楼层" />
                                <TextBlock Grid.Column="3" FontWeight="SemiBold" Text="页面" />
                                <TextBlock Grid.Column="4" FontWeight="SemiBold" Text="设备名" />
                                <TextBlock Grid.Column="5" FontWeight="SemiBold" Text="区域" />
                                <TextBlock Grid.Column="6" FontWeight="SemiBold" Text="开关机状态" />
                                <TextBlock Grid.Column="7" FontWeight="SemiBold" Text="模式" />
                                <TextBlock Grid.Column="8" FontWeight="SemiBold" Text="风速" />
                                <TextBlock Grid.Column="9" FontWeight="SemiBold" Text="设置温度(℃)" />
                                <TextBlock Grid.Column="10" FontWeight="SemiBold" Text="环境温度(℃)" />
                                <TextBlock Grid.Column="11" FontWeight="SemiBold" Text="集控锁定状态" />
                            </Grid>
                        </ListView.Header>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid MinWidth="1620" Padding="{Binding DataContext.TableRowPadding, ElementName=DataRoot}" ColumnSpacing="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90" />
                                        <ColumnDefinition Width="86" />
                                        <ColumnDefinition Width="86" />
                                        <ColumnDefinition Width="210" />
                                        <ColumnDefinition Width="190" />
                                        <ColumnDefinition Width="92" />
                                        <ColumnDefinition Width="110" />
                                        <ColumnDefinition Width="92" />
                                        <ColumnDefinition Width="82" />
                                        <ColumnDefinition Width="100" />
                                        <ColumnDefinition Width="100" />
                                        <ColumnDefinition Width="140" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding Building}" TextTrimming="CharacterEllipsis" ToolTipService.ToolTip="{Binding Building}" />
                                    <TextBlock Grid.Column="1" Text="{Binding Zuo}" TextTrimming="CharacterEllipsis" ToolTipService.ToolTip="{Binding Zuo}" />
                                    <TextBlock Grid.Column="2" Text="{Binding FloorLabel}" TextTrimming="CharacterEllipsis" ToolTipService.ToolTip="{Binding FloorLabel}" />
                                    <TextBlock Grid.Column="3" Text="{Binding PageName}" TextTrimming="CharacterEllipsis" ToolTipService.ToolTip="{Binding PageName}" />
                                    <TextBlock Grid.Column="4" FontWeight="SemiBold" Text="{Binding Name}" TextTrimming="CharacterEllipsis" ToolTipService.ToolTip="{Binding Name}" />
                                    <TextBlock Grid.Column="5" Text="{Binding AreaType}" TextTrimming="CharacterEllipsis" ToolTipService.ToolTip="{Binding AreaType}" />
                                    <TextBlock Grid.Column="6" Text="{Binding OperatingStatus}" TextTrimming="CharacterEllipsis" ToolTipService.ToolTip="{Binding OperatingStatus}" />
                                    <TextBlock Grid.Column="7" Text="{Binding Mode}" TextTrimming="CharacterEllipsis" ToolTipService.ToolTip="{Binding Mode}" />
                                    <TextBlock Grid.Column="8" Text="{Binding Fan}" TextTrimming="CharacterEllipsis" ToolTipService.ToolTip="{Binding Fan}" />
                                    <TextBlock Grid.Column="9" Text="{Binding SetTemperature}" TextTrimming="CharacterEllipsis" ToolTipService.ToolTip="{Binding SetTemperature}" />
                                    <TextBlock Grid.Column="10" Text="{Binding IndoorTemperature}" TextTrimming="CharacterEllipsis" ToolTipService.ToolTip="{Binding IndoorTemperature}" />
                                    <TextBlock Grid.Column="11" Text="{Binding RealtimeLock}" TextTrimming="CharacterEllipsis" ToolTipService.ToolTip="{Binding RealtimeLock}" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                    <StackPanel
                        Grid.Row="1"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="6"
                        Visibility="{x:Bind ViewModel.EmptyStateVisibility, Mode=OneWay}">
                        <TextBlock HorizontalAlignment="Center" FontWeight="SemiBold" Text="没有符合条件的设备" />
                        <TextBlock
                            HorizontalAlignment="Center"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="调整筛选条件后重新查询。"
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>
                    <Border
                        Grid.Row="1"
                        Background="{ThemeResource LayerFillColorDefaultBrush}"
                        Opacity="0.96"
                        Visibility="{x:Bind ViewModel.LoadingStateVisibility, Mode=OneWay}">
                        <StackPanel
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Spacing="10">
                            <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}" />
                            <TextBlock HorizontalAlignment="Center" FontWeight="SemiBold" Text="正在查询设备数据" />
                            <TextBlock
                                HorizontalAlignment="Center"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="筛选结果和 Excel 导出会使用同一组条件。"
                                TextWrapping="WrapWholeWords" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource WorkbenchCardStyle}" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid Padding="14,10" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="设备详情" />
                    </Grid>
                    <StackPanel
                        Grid.Row="1"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="5"
                        Visibility="{x:Bind ViewModel.NoSelectionDetailVisibility, Mode=OneWay}">
                        <FontIcon FontSize="24" Glyph="&#xE8A7;" />
                        <TextBlock FontWeight="SemiBold" Text="请选择设备" />
                    </StackPanel>
                    <ScrollViewer
                        Grid.Row="1"
                        Padding="14,10"
                        VerticalScrollBarVisibility="Auto"
                        Visibility="{x:Bind ViewModel.DetailVisibility, Mode=OneWay}">
                        <StackPanel Spacing="14">
                            <StackPanel Spacing="5">
                                <TextBlock FontWeight="SemiBold" Text="基础信息" />
                                <TextBlock FontSize="17" FontWeight="SemiBold" Text="{x:Bind ViewModel.SelectedDevice.Name, Mode=OneWay, FallbackValue=--}" TextWrapping="WrapWholeWords" />
                                <TextBlock Text="{x:Bind ViewModel.SelectedDevice.DeviceId, Mode=OneWay, FallbackValue=--}" />
                                <TextBlock Text="{x:Bind ViewModel.SelectedDevice.Location, Mode=OneWay, FallbackValue=--}" TextWrapping="WrapWholeWords" />
                                <TextBlock Text="{x:Bind ViewModel.SelectedDevice.PageName, Mode=OneWay, FallbackValue=--}" TextWrapping="WrapWholeWords" />
                                <TextBlock Text="{x:Bind ViewModel.SelectedDevice.AreaType, Mode=OneWay, FallbackValue=--}" />
                            </StackPanel>
                            <StackPanel Spacing="5">
                                <TextBlock FontWeight="SemiBold" Text="采集值" />
                                <TextBlock Text="{x:Bind ViewModel.SelectedDevice.OperatingStatus, Mode=OneWay, FallbackValue=--}" />
                                <TextBlock Text="{x:Bind ViewModel.SelectedDevice.Mode, Mode=OneWay, FallbackValue=--}" />
                                <TextBlock Text="{x:Bind ViewModel.SelectedDevice.Fan, Mode=OneWay, FallbackValue=--}" />
                                <TextBlock Text="{x:Bind ViewModel.SelectedDevice.SetTemperature, Mode=OneWay, FallbackValue=--}" />
                                <TextBlock Text="{x:Bind ViewModel.SelectedDevice.IndoorTemperature, Mode=OneWay, FallbackValue=--}" />
                            </StackPanel>
                            <StackPanel Spacing="5">
                                <TextBlock FontWeight="SemiBold" Text="实时值" />
                                <TextBlock Text="{x:Bind ViewModel.SelectedDevice.RealtimeMatchLabel, Mode=OneWay, FallbackValue=--}" TextWrapping="WrapWholeWords" />
                                <TextBlock Text="{x:Bind ViewModel.SelectedDevice.RealtimePower, Mode=OneWay, FallbackValue=--}" />
                                <TextBlock Text="{x:Bind ViewModel.SelectedDevice.RealtimeLock, Mode=OneWay, FallbackValue=--}" />
                                <TextBlock Text="{x:Bind ViewModel.SelectedDevice.RealtimePointSummary, Mode=OneWay, FallbackValue=--}" TextWrapping="WrapWholeWords" />
                                <TextBlock Text="{x:Bind ViewModel.SelectedDevice.RealtimeModbus, Mode=OneWay, FallbackValue=--}" TextWrapping="WrapWholeWords" />
                            </StackPanel>
                            <StackPanel Spacing="5">
                                <TextBlock FontWeight="SemiBold" Text="质量与审计" />
                                <TextBlock Text="{x:Bind ViewModel.SelectedDevice.HealthLabel, Mode=OneWay, FallbackValue=--}" />
                                <TextBlock Text="{x:Bind ViewModel.SelectedDevice.IssueSummary, Mode=OneWay, FallbackValue=--}" TextWrapping="WrapWholeWords" />
                            </StackPanel>
                            <StackPanel Spacing="5">
                                <TextBlock FontWeight="SemiBold" Text="数据上下文" />
                                <TextBlock Text="{x:Bind ViewModel.DataStateText, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>

        </Grid>
    </Grid>
</Page>
