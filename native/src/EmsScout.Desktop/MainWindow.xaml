<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="EmsScout.Desktop.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:EmsScout.Desktop"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="EMS Scout"
    mc:Ignorable="d">
    <Grid x:Name="RootGrid" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <InfoBar
            x:Name="StartupFailureBar"
            Grid.Row="0"
            IsClosable="False"
            IsOpen="False"
            Severity="Error"
            Title="数据库启动迁移失败">
            <InfoBar.Content>
                <StackPanel Spacing="8">
                    <TextBlock x:Name="StartupFailureMessage" TextWrapping="WrapWholeWords" />
                    <Button
                        x:Name="RetryStartupMigrationButton"
                        Click="RetryStartupMigration_Click"
                        Content="重试数据库迁移" />
                </StackPanel>
            </InfoBar.Content>
            <InfoBar.ActionButton>
                <Button Click="OpenSettings_Click" Content="打开系统设置" />
            </InfoBar.ActionButton>
        </InfoBar>
        <NavigationView
            x:Name="NavView"
            Grid.Row="1"
            IsBackButtonVisible="Collapsed"
            OpenPaneLength="180"
            IsPaneToggleButtonVisible="True"
            IsSettingsVisible="False"
            SelectionChanged="NavView_SelectionChanged">
            <NavigationView.MenuItems>
                <NavigationViewItem
                    Content="工作台"
                    IsSelected="True"
                    Tag="workbench">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE80F;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="采集" Tag="collection">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE7C1;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="设备数据" Tag="devices">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE8A5;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="区域组" Tag="rules">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE707;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="审计" Tag="audit">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE9D9;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>
            <NavigationView.FooterMenuItems>
                <NavigationViewItem Content="系统设置" Tag="settings">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE713;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="诊断" Tag="diagnostics">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE946;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.FooterMenuItems>
            <Frame x:Name="NavFrame" />
        </NavigationView>
    </Grid>
</Window>
