{
  "name": "ems-tool",
  "version": "1.0.0",
  "description": "Playwright + Edge CDP → SmartPiEMS 空调采集与数据管理",
  "main": "electron/main.js",
  "scripts": {
    "enum": "node src/enumerate.js",
    "enum:dry": "node src/enumerate.js --dry",
    "enum:edge": "node src/enumerate.js --edge",
    "enum:edge:append": "node src/enumerate.js --edge --append",
    "enum:edge:dry": "node src/enumerate.js --edge --dry",
    "collect": "node src/collect.js",
    "quality": "node scripts/quality-report.js",
    "legacy:panel": "node scripts/legacy-gate.js EMS_ENABLE_LEGACY_PANEL legacy-web-panel && node src/panel/server.js",
    "legacy:desktop": "node scripts/legacy-gate.js EMS_ENABLE_LEGACY_PANEL legacy-electron-desktop && electron .",
    "native:run": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/run-native.ps1",
    "native:build": "dotnet build native/EmsScout.Native.slnx -c Debug --no-restore /p:UseSharedCompilation=false",
    "native:test": "dotnet test native/tests/EmsScout.Tests/EmsScout.Tests.csproj -c Debug --no-restore /p:UseSharedCompilation=false",
    "legacy:restore-node-native": "node scripts/restore-node-native.js",
    "legacy:pack:win": "node scripts/legacy-gate.js EMS_ENABLE_LEGACY_PANEL legacy-electron-pack && electron-builder --win --dir && npm run legacy:restore-node-native",
    "legacy:dist:win": "node scripts/legacy-gate.js EMS_ENABLE_LEGACY_PANEL legacy-electron-dist && electron-builder --win nsis && npm run legacy:restore-node-native",
    "legacy:dist:portable": "node scripts/legacy-gate.js EMS_ENABLE_LEGACY_PANEL legacy-electron-portable && electron-builder --win portable && npm run legacy:restore-node-native",
    "self-test": "node scripts/self-test.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "better-sqlite3": "^12.10.0",
    "playwright": "^1.60.0",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz"
  },
  "devDependencies": {
    "electron": "^39.2.7",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.ems.data.desktop",
    "productName": "EMS Legacy Web Panel",
    "asar": false,
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "src/**/*",
      "scripts/**/*",
      "web/**/*",
      "data/**/*",
      "docs/**/*",
      "examples/**/*",
      "out/ac.db",
      "out/enum_full_v5.json",
      "out/quality_report*.json",
      "out/quality_report*.txt",
      "out/realtime_*_latest.json",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "${productName}-Setup-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "EMS Legacy Web Panel"
    },
    "npmRebuild": true,
    "afterPack": "scripts/electron-after-pack.js"
  }
}
